<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentFood.MobileApp.Pages.LoginPage"
             BackgroundColor="#F7F3EE"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Title="Đăng nhập">

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,32"
                             Spacing="18">
            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 28"
                    Padding="24,32">
                <VerticalStackLayout Spacing="18">
                    <Image Source="logo.png"
                           HeightRequest="70"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Chào mừng quay trở lại"
                               FontSize="24"
                               FontAttributes="Bold"
                               FontFamily="RobotoBold"
                               HorizontalTextAlignment="Center"
                               TextColor="#1F1B16" />
                        <Label Text="Đăng nhập để đặt bữa ăn tiếp theo của bạn"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               TextColor="#8A847E" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email"
                               FontSize="14"
                               TextColor="#5B5147" />
                        <Border Stroke="#E8D8C6"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#FFFDFC"
                                Padding="14,6">
                            <Entry x:Name="EmailEntry"
                                   Placeholder="Nhập địa chỉ email"
                                   Keyboard="Email"
                                   TextColor="#1F1B16"
                                   PlaceholderColor="#B4AAA0" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Mật khẩu"
                               FontSize="14"
                               TextColor="#5B5147" />
                        <Border Stroke="#E8D8C6"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#FFFDFC"
                                Padding="14,6">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="0"
                                       Placeholder="••••••••"
                                       IsPassword="True"
                                       TextColor="#1F1B16"
                                       PlaceholderColor="#B4AAA0" />
                                <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center">
                                    <Image x:Name="TogglePasswordIcon" Source="visibility.png" Aspect="AspectFit" HeightRequest="24" WidthRequest="24">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTogglePasswordClicked" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <HorizontalStackLayout HorizontalOptions="End">
                        <Label Text="Quên mật khẩu?"
                               TextColor="#A76020"
                               FontAttributes="Bold" />
                    </HorizontalStackLayout>

                    <Button x:Name="LoginButton"
                            Text="Đăng nhập"
                            HeightRequest="56"
                            CornerRadius="18"
                            BackgroundColor="#FF8A00"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnLoginClicked" />

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4">
                        <Label Text="Chưa có tài khoản?"
                               TextColor="#8A847E" />
                        <Label Text="Đăng ký ngay"
                               TextColor="#A76020"
                               FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
