@model IEnumerable<StudentFood.WebAdmin.Models.Food>
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Thực đơn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #FDF9F3;
            --primary-orange: #FF8A00;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --border-color: #F0EBE1;
            --bg-card: #FFFFFF;
            --bg-hover: #FFF3E0;
        }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }

        /* Sidebar */
        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); transition: color 0.2s; }
        .menu-item:hover { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i { color: var(--primary-orange); }
        .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; transition: color 0.2s; }
        .logout-btn:hover { color: var(--text-dark); }

        /* Main */
        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
        .page-title { font-size: 24px; font-weight: 800; margin: 0; }
        .page-subtitle { font-size: 13px; color: var(--text-gray); margin: 4px 0 0; }

        /* Buttons */
        .btn-orange { background: var(--primary-orange); color: #fff; border: none; border-radius: 12px; padding: 10px 20px; font-weight: 700; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; transition: background 0.2s; }
        .btn-orange:hover { background: #e07a00; color: #fff; }
        .btn-ghost { background: var(--bg-hover); color: var(--text-dark); border: none; border-radius: 10px; padding: 7px 14px; font-weight: 600; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: background 0.2s; }
        .btn-ghost:hover { background: #f0dfc4; color: var(--text-dark); }
        .btn-danger-soft { background: #FEE2E2; color: #DC2626; border: none; border-radius: 10px; padding: 7px 14px; font-weight: 600; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: background 0.2s; }
        .btn-danger-soft:hover { background: #FECACA; color: #B91C1C; }

        /* Search */
        .search-wrap { position: relative; }
        .search-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-gray); font-size: 14px; }
        .search-wrap input { background: #fff; border: 1.5px solid var(--border-color); border-radius: 12px; padding: 10px 16px 10px 40px; width: 280px; font-size: 14px; font-family: inherit; outline: none; color: var(--text-dark); }
        .search-wrap input:focus { border-color: var(--primary-orange); }

        /* Table Card */
        .table-card { background: #fff; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); overflow: hidden; }
        .table-card-header { padding: 20px 24px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; }
        .table-card-title { font-size: 16px; font-weight: 700; margin: 0; }
        .table-responsive-wrap { overflow-x: auto; }

        table.foods-table { width: 100%; border-collapse: collapse; }
        table.foods-table thead tr { background: var(--bg-main); }
        table.foods-table th { padding: 13px 16px; font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid var(--border-color); white-space: nowrap; }
        table.foods-table td { padding: 14px 16px; font-size: 14px; font-weight: 500; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
        table.foods-table tr:last-child td { border-bottom: none; }
        table.foods-table tr:hover td { background: #FFFBF5; }
        table.foods-table tr { transition: background 0.15s; }

        .food-img { width: 52px; height: 52px; object-fit: cover; border-radius: 12px; background: var(--bg-main); }
        .food-img-placeholder { width: 52px; height: 52px; border-radius: 12px; background: var(--bg-main); display: flex; align-items: center; justify-content: center; color: var(--text-gray); font-size: 20px; }
        .food-name { font-weight: 700; color: var(--text-dark); font-size: 14px; }
        .food-desc { font-size: 12px; color: var(--text-gray); margin-top: 2px; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .price-tag { font-weight: 700; color: var(--primary-orange); }
        .canteen-badge { background: #FFF3E0; color: #9A3B00; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; display: inline-block; }
        .cat-badge { background: #F0EBE1; color: #5B4A3A; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; display: inline-block; }
        .badge-available { background: #D1FAE5; color: #065F46; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
        .badge-unavailable { background: #FEE2E2; color: #991B1B; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
        .action-group { display: flex; gap: 6px; }

        /* Empty state */
        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-state i { font-size: 48px; color: var(--border-color); margin-bottom: 16px; }
        .empty-state p { color: var(--text-gray); font-size: 15px; }

        /* ===== Responsive ===== */
        @@media (max-width: 1366px) {
            .main-content {
                padding: 24px 24px;
            }
        }

        @@media (max-width: 1200px) {
            .sidebar {
                width: 220px;
            }
            .main-content {
                margin-left: 220px;
                padding: 20px 20px;
            }
            .page-title {
                font-size: 20px;
            }
            .search-wrap input {
                width: 200px;
            }
            table.foods-table th,
            table.foods-table td {
                padding: 10px 12px;
                font-size: 13px;
            }
        }

        @@media (max-width: 992px) {
            .sidebar {
                width: 200px;
            }
            .main-content {
                margin-left: 200px;
                padding: 16px 16px;
            }
            .sidebar-header {
                padding: 16px;
            }
            .sidebar-menu {
                padding: 8px 12px;
            }
            .menu-item {
                padding: 10px 12px;
                font-size: 13px;
            }
            .sidebar-footer {
                padding: 16px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            .table-card-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            .search-wrap input {
                width: 100%;
            }
            .stats-row {
                gap: 10px;
            }
            .stat-mini {
                padding: 14px 16px;
                min-width: 120px;
            }
            .stat-mini-value {
                font-size: 18px;
            }
        }

        @@media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
                flex-direction: row;
                flex-wrap: wrap;
                align-items: center;
                padding: 8px 16px;
            }
            .sidebar-header {
                padding: 4px 0;
            }
            .sidebar-header img {
                height: 40px;
            }
            .sidebar-menu {
                display: flex;
                gap: 4px;
                padding: 0;
                margin: 0 12px;
                flex-grow: 1;
            }
            .menu-item {
                padding: 6px 10px;
                font-size: 11px;
                margin-bottom: 0;
                white-space: nowrap;
            }
            .sidebar-footer {
                display: none;
            }
            .main-content {
                margin-left: 0;
                padding: 12px;
            }
            .page-title {
                font-size: 18px;
            }
            .stat-mini {
                min-width: calc(50% - 10px);
            }
        }

        /* Stats row */
        .stats-row { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
        .stat-mini { background: #fff; border-radius: 16px; padding: 18px 22px; flex: 1; min-width: 140px; box-shadow: 0 2px 12px rgba(0,0,0,0.03); }
        .stat-mini-label { font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
        .stat-mini-value { font-size: 22px; font-weight: 800; }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info">
                    <h6>Quản trị viên</h6>
                    <p>Admin</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <div>
                <h1 class="page-title">Quản lý Thực đơn</h1>
                <p class="page-subtitle">Quản lý toàn bộ món ăn trong hệ thống</p>
            </div>
            <a asp-action="Create" class="btn-orange">
                <i class="fas fa-plus"></i> Thêm món mới
            </a>
        </div>

        <!-- Stats row -->
        @{
            var totalFoods = Model.Count();
            var availableFoods = Model.Count(f => f.IsAvailable);
            var unavailableFoods = totalFoods - availableFoods;
        }
        <div class="stats-row">
            <div class="stat-mini">
                <div class="stat-mini-label">Tổng số món</div>
                <div class="stat-mini-value">@totalFoods</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-label">Đang bán</div>
                <div class="stat-mini-value" style="color: #16A34A;">@availableFoods</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-label">Tạm dừng</div>
                <div class="stat-mini-value" style="color: #DC2626;">@unavailableFoods</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-label">Số căn tin</div>
                <div class="stat-mini-value" style="color: var(--primary-orange);">@Model.Select(f => f.CanteenId).Distinct().Count()</div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="table-card">
            <div class="table-card-header">
                <h2 class="table-card-title">Danh sách món ăn</h2>
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" placeholder="Tìm theo tên, căn tin...">
                </div>
            </div>
            <div class="table-responsive-wrap">
                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <i class="fas fa-utensils"></i>
                        <p>Chưa có món ăn nào. <a asp-action="Create" style="color: var(--primary-orange); font-weight: 700;">Thêm ngay!</a></p>
                    </div>
                }
                else
                {
                    <table class="foods-table" id="foodsTable">
                        <thead>
                            <tr>
                                <th style="width:60px">#</th>
                                <th>Món ăn</th>
                                <th>Căn tin</th>
                                <th>Danh mục</th>
                                <th>Giá</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th style="text-align:right">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="color: var(--text-gray); font-size: 13px; font-weight: 600;">@item.Id</td>
                                    <td>
                                        <div style="display:flex; align-items:center; gap:12px;">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" alt="@item.Name" class="food-img" />
                                            }
                                            else
                                            {
                                                <div class="food-img-placeholder"><i class="fas fa-image"></i></div>
                                            }
                                            <div>
                                                <div class="food-name">@item.Name</div>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <div class="food-desc">@item.Description</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="canteen-badge">@(item.Canteen?.Name ?? "—")</span></td>
                                    <td><span class="cat-badge">@(item.Category?.Name ?? "—")</span></td>
                                    <td class="price-tag">@item.Price.ToString("N0")đ</td>
                                    <td>
                                        @if (item.IsAvailable)
                                        {
                                            <span class="badge-available"><i class="fas fa-check-circle"></i> Đang bán</span>
                                        }
                                        else
                                        {
                                            <span class="badge-unavailable"><i class="fas fa-pause-circle"></i> Tạm dừng</span>
                                        }
                                    </td>
                                    <td style="color: var(--text-gray); font-size: 13px;">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="action-group" style="justify-content:flex-end;">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-ghost">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-ghost">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-danger-soft">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="padding: 16px 24px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 13px; color: var(--text-gray);">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
                </div>
                <div style="display: flex; gap: 6px;">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1 })" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
                    }
                    @{
                        var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        var endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a href="@Url.Action("Index", new { page = i })" class="pagination-btn @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1 })" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
                    }
                </div>
            </div>
        }
    </div>

    <style>
        .pagination-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 10px;
            border: 1.5px solid var(--border-color); background: #fff;
            color: var(--text-dark); font-size: 13px; font-weight: 700;
            text-decoration: none; transition: all 0.2s;
        }
        .pagination-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .pagination-btn.active { background: var(--primary-orange); color: #fff; border-color: var(--primary-orange); }
    </style>

    <script>
        document.getElementById('searchInput')?.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#foodsTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(q) ? '' : 'none';
            });
        });
    </script>
</body>
</html>
