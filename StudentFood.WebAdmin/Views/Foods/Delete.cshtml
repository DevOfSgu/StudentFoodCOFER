@model StudentFood.WebAdmin.Models.Food
@{
    Layout = null;
    ViewData["Title"] = "Xóa món ăn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg-main: #FDF9F3; --primary-orange: #FF8A00; --text-dark: #2A241F; --text-gray: #8A847E; --border-color: #F0EBE1; --bg-hover: #FFF3E0; }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }

        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); }
        .menu-item:hover, .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i, .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; }

        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding-top: 60px; }
        .delete-container { max-width: 560px; width: 100%; }

        .delete-card { background: #fff; border-radius: 24px; box-shadow: 0 8px 32px rgba(0,0,0,0.07); overflow: hidden; }
        .delete-card-top { padding: 32px 32px 24px; text-align: center; }
        .danger-icon { width: 72px; height: 72px; background: #FEE2E2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
        .danger-icon i { font-size: 28px; color: #DC2626; }
        .delete-title { font-size: 22px; font-weight: 800; margin: 0 0 8px; }
        .delete-subtitle { font-size: 14px; color: var(--text-gray); margin: 0; }

        .food-preview { margin: 20px 32px; border-radius: 16px; background: var(--bg-main); padding: 16px; display: flex; gap: 16px; align-items: center; border: 1.5px solid var(--border-color); }
        .food-preview-img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; background: #EEE; flex-shrink: 0; }
        .food-preview-img-placeholder { width: 64px; height: 64px; border-radius: 12px; background: var(--bg-hover); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--primary-orange); font-size: 22px; }
        .food-preview-name { font-size: 16px; font-weight: 800; margin-bottom: 4px; }
        .food-preview-meta { font-size: 13px; color: var(--text-gray); }
        .food-preview-price { font-size: 17px; font-weight: 800; color: var(--primary-orange); margin-top: 4px; }

        .warning-box { margin: 0 32px 24px; background: #FFF7ED; border: 1.5px solid #FED7AA; border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; align-items: flex-start; }
        .warning-box i { color: #EA580C; margin-top: 2px; flex-shrink: 0; }
        .warning-box p { margin: 0; font-size: 13px; color: #9A3412; font-weight: 600; }

        .delete-actions { padding: 20px 32px 32px; display: flex; gap: 12px; }
        form.delete-form { display: contents; }
        .btn-danger-full { background: #DC2626; color: #fff; border: none; border-radius: 12px; padding: 13px 0; font-weight: 700; font-size: 15px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; flex: 1; transition: background 0.2s; font-family: inherit; }
        .btn-danger-full:hover { background: #B91C1C; }
        .btn-ghost { background: var(--bg-main); color: var(--text-dark); border: 1.5px solid var(--border-color); border-radius: 12px; padding: 13px 0; font-weight: 700; font-size: 14px; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px; flex: 1; transition: all 0.2s; }
        .btn-ghost:hover { border-color: var(--primary-orange); color: var(--primary-orange); }

        @media (max-width: 1366px) { .main-content { padding: 24px; } }
        @media (max-width: 1200px) { .sidebar { width: 220px; } .main-content { margin-left: 220px; padding: 20px; } .sidebar-header img { height: 60px; } }
        @media (max-width: 992px) { .sidebar { width: 200px; } .main-content { margin-left: 200px; padding: 16px; } .sidebar-header { padding: 16px; } .sidebar-menu { padding: 8px 12px; } .menu-item { padding: 10px 12px; font-size: 13px; } .sidebar-footer { padding: 16px; } .delete-actions { flex-direction: column; } }
        @media (max-width: 768px) { .sidebar { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border-color); flex-direction: row; flex-wrap: wrap; align-items: center; padding: 8px 16px; } .sidebar-header { padding: 4px 0; } .sidebar-header img { height: 40px; } .sidebar-menu { display: flex; gap: 4px; padding: 0; margin: 0 12px; flex-grow: 1; } .menu-item { padding: 6px 10px; font-size: 11px; margin-bottom: 0; white-space: nowrap; } .sidebar-footer { display: none; } .main-content { margin-left: 0; padding: 12px; padding-top: 20px; } .delete-card-top { padding: 24px 20px; } .food-preview { margin: 16px 20px; } .warning-box { margin: 0 20px 20px; } .delete-actions { padding: 16px 20px 24px; } }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info"><h6>Quản trị viên</h6><p>Admin</p></div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="delete-container">
            <div class="delete-card">
                <div class="delete-card-top">
                    <div class="danger-icon">
                        <i class="fas fa-trash-alt"></i>
                    </div>
                    <h2 class="delete-title">Xác nhận xóa món ăn</h2>
                    <p class="delete-subtitle">Hành động này không thể hoàn tác. Món ăn sẽ bị xóa vĩnh viễn.</p>
                </div>

                <div class="food-preview">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="food-preview-img" alt="@Model.Name">
                    }
                    else
                    {
                        <div class="food-preview-img-placeholder"><i class="fas fa-utensils"></i></div>
                    }
                    <div>
                        <div class="food-preview-name">@Model.Name</div>
                        <div class="food-preview-meta">
                            @(Model.Canteen?.Name ?? "—") &nbsp;·&nbsp; @(Model.Category?.Name ?? "—")
                        </div>
                        <div class="food-preview-price">@Model.Price.ToString("N0")đ</div>
                    </div>
                </div>

                <div class="warning-box">
                    <i class="fas fa-exclamation-triangle"></i>
                    <p>Xóa món ăn sẽ ảnh hưởng đến lịch sử đơn hàng và dữ liệu liên quan. Hãy chắc chắn trước khi thực hiện.</p>
                </div>

                <div class="delete-actions">
                    <form asp-action="Delete" class="delete-form">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn-danger-full">
                            <i class="fas fa-trash"></i> Xóa vĩnh viễn
                        </button>
                    </form>
                    <a asp-action="Index" class="btn-ghost">
                        <i class="fas fa-times"></i> Hủy bỏ
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
