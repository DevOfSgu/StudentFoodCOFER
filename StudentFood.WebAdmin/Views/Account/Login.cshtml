@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - StudentFood COFER</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #FF8A00;
            --primary-hover: #E07A00;
            --bg-color: #F7F5F0;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --input-bg: #F5EFE9;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-dark);
        }

        .brand-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .brand-header img {
            height: 120px; /* Tăng kích thước logo từ 40px lên 120px */
            object-fit: contain;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.05);
            padding: 40px;
            width: 100%;
            max-width: 420px;
            text-align: center;
        }

        .login-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--text-gray);
            margin-bottom: 30px;
            font-weight: 500;
        }

        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }

        .form-label {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
        }

        .forgot-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-gray);
            font-size: 16px;
        }

        .input-wrapper .eye-icon {
            left: auto;
            right: 16px;
            cursor: pointer;
        }

        .form-control {
            background-color: var(--input-bg);
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 14px 16px 14px 44px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark);
            transition: all 0.3s;
        }

        .form-control:focus {
            background-color: white;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(255, 138, 0, 0.1);
        }

        .checkbox-wrapper {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
            text-align: left;
        }

        .checkbox-wrapper input {
            margin-right: 10px;
            width: 16px;
            height: 16px;
            accent-color: var(--primary);
        }

        .checkbox-wrapper label {
            font-size: 13px;
            color: var(--text-gray);
            font-weight: 500;
            margin: 0;
        }

        .btn-primary {
            background-color: var(--primary);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 15px;
            width: 100%;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(255, 138, 0, 0.25);
        }

        .divider {
            height: 1px;
            background-color: #EFEAE4;
            margin: 24px 0;
        }

        .create-account {
            font-size: 13px;
            color: var(--text-gray);
            font-weight: 500;
        }

        .create-account a {
            color: var(--primary-brown);
            text-decoration: none;
            font-weight: 700;
            color: #A05A19;
        }

        .footer-text {
            text-align: center;
            margin-top: 30px;
            font-size: 11px;
            color: var(--text-gray);
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .footer-text i {
            margin-right: 4px;
        }

        .error-alert {
            background-color: #fee2e2;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 13px;
            font-weight: 600;
            text-align: left;
        }
    </style>
</head>
<body>

    <div class="brand-header">
        <img src="/logo.png" alt="StudentFood COFER">
    </div>

    <div class="login-card">
        <h1 class="login-title">Chào mừng trở lại</h1>
        <p class="login-subtitle">Đăng nhập vào hệ thống quản lý StudentFood</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-alert">
                <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="form-group">
                <label class="form-label">Email</label>
                <div class="input-wrapper">
                    <i class="far fa-envelope"></i>
                    <input type="email" name="email" class="form-control" required placeholder="admin@studentfood.com...">
                </div>
            </div>

            <div class="form-group">
                <div class="form-label">
                    <span>Mật khẩu</span>
                    <a href="#" class="forgot-link">Quên mật khẩu?</a>
                </div>
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="password" class="form-control" required placeholder="••••••••">
                    <i class="far fa-eye eye-icon"></i>
                </div>
            </div>

            <div class="checkbox-wrapper">
                <input type="checkbox" id="remember">
                <label for="remember">Ghi nhớ đăng nhập 30 ngày</label>
            </div>

            <button type="submit" class="btn btn-primary">Đăng Nhập</button>
        </form>

        <div class="divider"></div>

        <div class="create-account">
            Chưa có tài khoản? <a href="#">Đăng ký ngay</a>
        </div>
    </div>

    <div class="footer-text">
        <p style="margin-bottom: 4px;"><i class="fas fa-shield-alt"></i> CỔNG THÔNG TIN BẢO MẬT</p>
        <p>© @DateTime.Now.Year StudentFood COFER. Hệ thống được giám sát an ninh liên tục.</p>
    </div>

</body>
</html>
