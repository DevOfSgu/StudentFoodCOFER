@model IEnumerable<StudentFood.WebAdmin.Models.Canteen>
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Đối tác Căn tin";
    var statsMap = ViewBag.StatsMap as Dictionary<int, StudentFood.WebAdmin.Controllers.CanteenStatsDto>;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #FDF9F3;
            --bg-sidebar: #FFFFFF;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --primary-orange: #FF8A00;
            --primary-brown: #FF8A00;
            --bg-card: #FFFFFF;
            --border-color: #F0EBE1;
            --success-green: #22C55E;
            --bg-hover: #FFF3E0;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 250px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 30px 24px;
            text-align: center;
        }

        .sidebar-menu {
            padding: 10px 16px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            transition: color 0.2s;
        }

        .menu-item:hover {
            background-color: var(--bg-hover);
        }

        .menu-item.active {
            background-color: var(--bg-hover);
            color: var(--primary-orange);
        }

        .menu-item.active i {
            color: var(--primary-orange);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
        }

        .user-profile {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 12px;
        }

        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info p {
            margin: 0;
            font-size: 12px;
            color: var(--text-gray);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .logout-btn i {
            margin-right: 10px;
        }

        .logout-btn:hover {
            color: var(--text-dark);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: 250px;
            padding: 30px 40px;
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
        }

        /* Cards & Components */
        .section-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            margin-bottom: 24px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin: 0;
        }

        .btn-orange {
            background-color: var(--primary-orange);
            color: white;
            padding: 10px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background-color 0.2s;
        }

        .btn-orange:hover {
            background-color: #E07A00;
            color: white;
        }

        /* Table custom styling */
        .table-custom {
            width: 100%;
            border-collapse: collapse;
        }

        .table-custom th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-gray);
            text-transform: uppercase;
            border-bottom: 1px solid var(--border-color);
        }

        .table-custom td {
            padding: 16px;
            font-size: 14px;
            font-weight: 600;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }

        .badge-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        
        .badge-open { background: #D1FAE5; color: #166534; }
        .badge-closed { background: #FEE2E2; color: #991B1B; }

        .btn-action-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: transparent;
            color: var(--text-dark);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.2s;
            margin-right: 4px;
        }

        .btn-action-icon:hover {
            background: var(--bg-hover);
            color: var(--primary-orange);
            border-color: var(--primary-orange);
        }

        .table-responsive-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* ===== Responsive ===== */
        @media (max-width: 1366px) {
            .main-content {
                padding: 24px 24px;
            }
        }

        @media (max-width: 1200px) {
            .sidebar {
                width: 220px;
            }
            .main-content {
                margin-left: 220px;
                padding: 20px 20px;
            }
            .sidebar-header img {
                height: 90px;
            }
            .page-title {
                font-size: 20px;
            }
            .section-title {
                font-size: 16px;
            }
            .table-custom th,
            .table-custom td {
                padding: 12px;
                font-size: 13px;
            }
        }

        @media (max-width: 992px) {
            .sidebar {
                width: 200px;
            }
            .main-content {
                margin-left: 200px;
                padding: 16px 16px;
            }
            .sidebar-header {
                padding: 16px;
            }
            .sidebar-header img {
                height: 70px;
            }
            .sidebar-menu {
                padding: 8px 12px;
            }
            .menu-item {
                padding: 10px 12px;
                font-size: 13px;
            }
            .sidebar-footer {
                padding: 16px;
            }
            .section-card {
                padding: 16px;
            }
            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
                flex-direction: row;
                flex-wrap: wrap;
                align-items: center;
                padding: 8px 16px;
            }
            .sidebar-header {
                padding: 4px 0;
            }
            .sidebar-header img {
                height: 50px;
                margin-bottom: 0;
            }
            .sidebar-menu {
                display: flex;
                gap: 4px;
                padding: 0;
                margin: 0 12px;
                flex-grow: 1;
            }
            .menu-item {
                padding: 6px 10px;
                font-size: 11px;
                margin-bottom: 0;
                white-space: nowrap;
            }
            .sidebar-footer {
                display: none;
            }
            .main-content {
                margin-left: 0;
                padding: 12px;
            }
            .top-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
            }
            .page-title {
                font-size: 18px;
            }
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" style="height: 120px; object-fit: contain; margin-bottom: 10px;">
        </div>
        
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item">
                <i class="fas fa-border-all"></i> Tổng quan
            </a>
            <a href="/Orders" class="menu-item">
                <i class="fas fa-shopping-cart"></i> Đơn hàng
            </a>
            <a href="/Canteens" class="menu-item active">
                <i class="fas fa-store"></i> Đối tác
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="/img/avatar_admin.png" alt="Admin" class="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19'">
                <div class="user-info">
                    <h6>@Context.Session.GetString("UserName")</h6>
                    <p>Quản trị viên</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <h2 class="page-title">Quản lý Đối tác Căn tin</h2>
        </div>

        <div class="section-card">
            <div class="section-header">
                <h3 class="section-title">Danh sách căn tin liên kết</h3>
                <a asp-action="Create" class="btn-orange">
                    <i class="fas fa-plus"></i> Thêm đối tác mới
                </a>
            </div>

            <div class="table-responsive-wrap">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>Tên Cửa Hàng / Căn Tin</th>
                        <th>Quản lý (Chủ)</th>
                        <th>Chiết khấu</th>
                        <th>Trạng thái</th>
                        <th>Số đơn giao</th>
                        <th>Doanh thu quầy</th>
                        <th>Phí hệ thống</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        var totalOrders = 0;
                        var totalRevenue = 0m;
                        var totalCommission = 0m;
                        
                        if (statsMap != null && statsMap.ContainsKey(item.Id))
                        {
                            var stats = statsMap[item.Id];
                            totalOrders = stats.TotalOrders;
                            totalRevenue = stats.TotalRevenue;
                            totalCommission = stats.TotalCommission;
                        }

                        <tr>
                            <td>
                                <div><strong>@item.Name</strong></div>
                                <div style="font-size: 12px; color: var(--text-gray); font-weight: normal;">@item.Description</div>
                            </td>
                            <td>@item.Owner.FullName</td>
                            <td>@(item.CommissionRate * 100)%</td>
                            <td>
                                @if (string.Equals(item.Status, "open", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge-status badge-open">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-closed">Tạm đóng</span>
                                }
                            </td>
                            <td>@totalOrders.ToString("N0")</td>
                            <td class="text-success">@string.Format("{0:N0}đ", totalRevenue)</td>
                            <td style="color: var(--primary-orange)">@string.Format("{0:N0}đ", totalCommission)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Sửa"><i class="fas fa-edit"></i></a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="padding: 16px 24px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 13px; color: var(--text-gray);">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
                </div>
                <div style="display: flex; gap: 6px;">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1 })" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
                    }
                    @{
                        var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        var endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a href="@Url.Action("Index", new { page = i })" class="pagination-btn @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1 })" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
                    }
                </div>
            </div>
        }
    </div>

    <style>
        .pagination-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 10px;
            border: 1.5px solid var(--border-color); background: #fff;
            color: var(--text-dark); font-size: 13px; font-weight: 700;
            text-decoration: none; transition: all 0.2s;
        }
        .pagination-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .pagination-btn.active { background: var(--primary-orange); color: #fff; border-color: var(--primary-orange); }
    </style>
</body>
</html>
