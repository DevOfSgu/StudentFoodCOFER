@model List<StudentFood.WebAdmin.Models.Review>
@{
    Layout = null;
    ViewData["Title"] = "Đánh giá món ăn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - StudentFood COFER</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #F9F7F4;
            --bg-sidebar: #FAF8F5;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --primary-orange: #FF8A00;
            --primary-brown: #A05A19;
            --bg-card: #FFFFFF;
            --border-color: #EBE5DE;
            --success-green: #22C55E;
            --bg-hover: #EFEAE4;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 250px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 30px 24px;
            text-align: center;
        }

        .sidebar-header img {
            height: 120px;
            object-fit: contain;
            margin-bottom: 10px;
        }

        .sidebar-menu {
            padding: 10px 16px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            transition: color 0.2s;
        }

        .menu-item:hover {
            background-color: var(--bg-hover);
        }

        .menu-item.active {
            background-color: #EFE4D6;
            color: var(--text-dark);
        }

        .menu-item.active i {
            color: var(--text-dark);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
        }

        .user-profile {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 12px;
        }

        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info p {
            margin: 0;
            font-size: 12px;
            color: var(--text-gray);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 130px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .logout-btn i {
            margin-right: 10px;
        }

        .logout-btn:hover {
            color: var(--text-dark);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: 250px;
            padding: 30px 40px;
            min-height: 100vh;
            background-color: #FAFAFA;
        }

        .top-bar-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
            color: #92400E;
        }

        .page-subtitle {
            color: #666;
            font-size: 13px;
            font-weight: 500;
            margin: 4px 0 0;
        }

        /* Stats row */
        .stats-row {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card-clean {
            background: #FFFFFF;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #EAEAEA;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
            flex: 1;
        }

        .stat-card-clean .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .stat-card-clean .stat-title {
            color: #666;
            font-size: 11px;
            letter-spacing: 0;
            text-transform: none;
            font-weight: 600;
            margin: 0;
        }

        .stat-card-clean .stat-value {
            font-size: 28px;
            color: #111;
            font-weight: 800;
        }

        /* Review list card */
        .section-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            margin-bottom: 24px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin: 0;
        }

        /* Review card */
        .review-card {
            background: var(--bg-main);
            border-radius: 14px;
            padding: 20px;
            margin-bottom: 16px;
            border: 1px solid var(--border-color);
            transition: all 0.2s;
        }

        .review-card:hover {
            border-color: #D4C9BC;
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .review-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .review-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            background: var(--bg-hover);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-gray);
            font-size: 16px;
            flex-shrink: 0;
        }

        .review-user-name {
            font-weight: 700;
            font-size: 14px;
            margin: 0;
        }

        .review-user-meta {
            font-size: 12px;
            color: var(--text-gray);
            margin: 2px 0 0;
        }

        .review-rating {
            display: flex;
            gap: 3px;
            color: #F59E0B;
            font-size: 14px;
        }

        .review-rating .empty {
            color: #DDD;
        }

        .review-food-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #FFF3E0;
            color: #9A3B00;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .review-comment {
            font-size: 14px;
            color: #5B5147;
            line-height: 1.6;
            margin: 0;
        }

        .review-date {
            font-size: 12px;
            color: var(--text-gray);
            margin-top: 10px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state i {
            font-size: 48px;
            color: var(--border-color);
            margin-bottom: 16px;
        }

        .empty-state p {
            color: var(--text-gray);
            font-size: 15px;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header" style="text-align: center; padding: 20px 24px;">
            <img src="/logo.png" alt="Logo" style="height: 120px; object-fit: contain; margin-bottom: 10px;">
        </div>
        
        <div class="sidebar-menu">
            <a href="/CanteenDashboard" class="menu-item">
                <i class="fas fa-border-all"></i> Tổng quan
            </a>
            <a href="/CanteenDashboard/Foods" class="menu-item">
                <i class="fas fa-utensils"></i> Quản lý Món ăn
            </a>
            <a href="/CanteenDashboard/Reviews" class="menu-item active">
                <i class="fas fa-star"></i> Đánh giá
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="/img/avatar_canteen.png" alt="Canteen" class="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Canteen&background=FFF3E0&color=FF8A00'">
                <div class="user-info">
                    <h6>@Context.Session.GetString("UserName")</h6>
                    <p>@ViewBag.CanteenName</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="top-bar-custom">
            <div>
                <h2 class="page-title">Đánh giá món ăn</h2>
                <p class="page-subtitle">Phản hồi từ sinh viên về món ăn của @ViewBag.CanteenName</p>
            </div>
        </div>

        <!-- Stats row -->
        @{
            var totalReviews = Model.Count;
            var avgRating = totalReviews > 0 ? Model.Average(r => r.Rating) : 0;
            var fiveStar = Model.Count(r => r.Rating == 5);
            var fourStar = Model.Count(r => r.Rating == 4);
            var threeStar = Model.Count(r => r.Rating == 3);
            var twoStar = Model.Count(r => r.Rating == 2);
            var oneStar = Model.Count(r => r.Rating == 1);
        }
        <div class="stats-row">
            <div class="stat-card-clean">
                <div class="stat-header">
                    <i class="fas fa-comment" style="color: #B45309; font-size: 18px;"></i>
                    <h3 class="stat-title">TỔNG ĐÁNH GIÁ</h3>
                </div>
                <div class="stat-value">@totalReviews</div>
            </div>
            <div class="stat-card-clean">
                <div class="stat-header">
                    <i class="fas fa-star" style="color: #F59E0B; font-size: 18px;"></i>
                    <h3 class="stat-title">ĐIỂM TRUNG BÌNH</h3>
                </div>
                <div class="stat-value" style="color: #B45309;">@avgRating.ToString("F1")</div>
            </div>
            <div class="stat-card-clean">
                <div class="stat-header">
                    <i class="fas fa-smile" style="color: #10B981; font-size: 18px;"></i>
                    <h3 class="stat-title">5 SAO</h3>
                </div>
                <div class="stat-value" style="color: #16A34A;">@fiveStar</div>
            </div>
            <div class="stat-card-clean">
                <div class="stat-header">
                    <i class="fas fa-frown" style="color: #EF4444; font-size: 18px;"></i>
                    <h3 class="stat-title">1-2 SAO</h3>
                </div>
                <div class="stat-value" style="color: #DC2626;">@(oneStar + twoStar)</div>
            </div>
        </div>

        <!-- Review list -->
        <div class="section-card">
            <div class="section-header">
                <h3 class="section-title">Tất cả đánh giá</h3>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-star"></i>
                    <p>Chưa có đánh giá nào từ sinh viên.</p>
                </div>
            }
            else
            {
                @foreach (var review in Model)
                {
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-user">
                                <div class="review-avatar">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div>
                                    <div class="review-user-name">@review.Student.FullName</div>
                                    <div class="review-user-meta">Đơn #ORD-@review.OrderId</div>
                                </div>
                            </div>
                            <div class="review-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-star empty"></i>
                                    }
                                }
                            </div>
                        </div>
                        <div class="review-food-badge">
                            <i class="fas fa-utensils"></i> @review.Food.Name
                        </div>
                        @if (!string.IsNullOrEmpty(review.Comment))
                        {
                            <p class="review-comment">@review.Comment</p>
                        }
                        else
                        {
                            <p class="review-comment" style="font-style: italic; color: var(--text-gray);">(Không có bình luận)</p>
                        }
                        <div class="review-date">
                            <i class="far fa-clock"></i> @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
