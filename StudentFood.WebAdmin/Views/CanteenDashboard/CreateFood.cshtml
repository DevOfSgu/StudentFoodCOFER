@model StudentFood.WebAdmin.Models.Food
@{
    Layout = null;
    ViewData["Title"] = "Thêm món ăn mới";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - StudentFood COFER</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #F9F7F4;
            --bg-sidebar: #FAF8F5;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --primary-orange: #FF8A00;
            --primary-brown: #A05A19;
            --bg-card: #FFFFFF;
            --border-color: #EBE5DE;
            --success-green: #22C55E;
            --bg-hover: #EFEAE4;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 250px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 30px 24px;
            text-align: center;
        }

        .sidebar-header img {
            height: 120px;
            object-fit: contain;
            margin-bottom: 10px;
        }

        .sidebar-menu {
            padding: 10px 16px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            transition: color 0.2s;
        }

        .menu-item:hover {
            background-color: var(--bg-hover);
        }

        .menu-item.active {
            background-color: #EFE4D6;
            color: var(--text-dark);
        }

        .menu-item.active i {
            color: var(--text-dark);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
        }

        .user-profile {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 12px;
        }

        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info p {
            margin: 0;
            font-size: 12px;
            color: var(--text-gray);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 130px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .logout-btn i {
            margin-right: 10px;
        }

        .logout-btn:hover {
            color: var(--text-dark);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: 250px;
            padding: 30px 40px;
            min-height: 100vh;
            background-color: #FAFAFA;
        }

        .page-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 32px;
        }

        .back-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #fff;
            border: 1.5px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-dark);
            text-decoration: none;
            transition: all 0.2s;
        }

        .back-btn:hover {
            border-color: #B45309;
            color: #B45309;
        }

        .page-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0;
            color: #92400E;
        }

        .page-subtitle {
            font-size: 13px;
            color: var(--text-gray);
            margin: 2px 0 0;
        }

        /* Form card */
        .form-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            padding: 28px;
            margin-bottom: 24px;
        }

        .form-section-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0 0 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
        }

        .form-label {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 6px;
            display: block;
        }

        .form-control, .form-select {
            border: 1.5px solid var(--border-color);
            border-radius: 12px;
            padding: 11px 14px;
            font-size: 14px;
            font-family: inherit;
            color: var(--text-dark);
            background: #fff;
            transition: border-color 0.2s;
            width: 100%;
        }

        .form-control:focus, .form-select:focus {
            border-color: #B45309;
            outline: none;
            box-shadow: 0 0 0 3px rgba(180,83,9,0.12);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 90px;
        }

        .text-danger {
            color: #DC2626 !important;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        /* Toggle switch */
        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: var(--bg-main);
            border-radius: 14px;
            border: 1.5px solid var(--border-color);
        }

        .toggle-label {
            font-size: 14px;
            font-weight: 700;
        }

        .toggle-sub {
            font-size: 12px;
            color: var(--text-gray);
            margin-top: 2px;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 48px;
            height: 26px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            inset: 0;
            background: #DDD;
            border-radius: 26px;
            transition: 0.3s;
        }

        .slider:before {
            content: '';
            position: absolute;
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background: white;
            border-radius: 50%;
            transition: 0.3s;
        }

        input:checked + .slider {
            background: #B45309;
        }

        input:checked + .slider:before {
            transform: translateX(22px);
        }

        /* Image preview */
        .image-preview {
            width: 100%;
            height: 200px;
            border-radius: 14px;
            background: var(--bg-main);
            border: 2px dashed var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 12px;
        }

        .image-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 12px;
        }

        .image-preview-placeholder {
            text-align: center;
            color: var(--text-gray);
        }

        .image-preview-placeholder i {
            font-size: 32px;
            margin-bottom: 8px;
        }

        .image-preview-placeholder p {
            font-size: 13px;
            margin: 0;
        }

        .btn-orange {
            background: #B45309;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 12px 28px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
            font-family: inherit;
            text-decoration: none;
        }

        .btn-orange:hover {
            background: #92400E;
            color: #fff;
        }

        .btn-ghost {
            background: var(--bg-main);
            color: var(--text-dark);
            border: 1.5px solid var(--border-color);
            border-radius: 12px;
            padding: 12px 24px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            font-family: inherit;
        }

        .btn-ghost:hover {
            border-color: #B45309;
            color: #B45309;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header" style="text-align: center; padding: 20px 24px;">
            <img src="/logo.png" alt="Logo" style="height: 120px; object-fit: contain; margin-bottom: 10px;">
        </div>
        
        <div class="sidebar-menu">
            <a href="/CanteenDashboard" class="menu-item">
                <i class="fas fa-border-all"></i> Tổng quan
            </a>
            <a href="/CanteenDashboard/Foods" class="menu-item active">
                <i class="fas fa-utensils"></i> Quản lý Món ăn
            </a>
            <a href="/CanteenDashboard/Reviews" class="menu-item">
                <i class="fas fa-star"></i> Đánh giá
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="/img/avatar_canteen.png" alt="Canteen" class="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Canteen&background=FFF3E0&color=FF8A00'">
                <div class="user-info">
                    <h6>@Context.Session.GetString("UserName")</h6>
                    <p>@ViewBag.CanteenName</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <a href="/CanteenDashboard/Foods" class="back-btn"><i class="fas fa-arrow-left"></i></a>
            <div>
                <h1 class="page-title">Thêm món ăn mới</h1>
                <p class="page-subtitle">Điền đầy đủ thông tin bên dưới</p>
            </div>
        </div>

        <form asp-action="CreateFood" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:12px;font-size:13px;"></div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="form-card">
                        <p class="form-section-title">Thông tin cơ bản</p>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Tên món ăn <span style="color:#DC2626">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="VD: Cơm sườn bì chả" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Danh mục <span style="color:#DC2626">*</span></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Giá bán (VNĐ) <span style="color:#DC2626">*</span></label>
                                <input asp-for="Price" class="form-control" placeholder="VD: 25000" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Mô tả</label>
                                <textarea asp-for="Description" class="form-control" placeholder="Mô tả ngắn về món ăn..."></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="form-card mb-4">
                        <p class="form-section-title">Hình ảnh</p>
                        <div class="image-preview" id="imagePreview">
                            <div class="image-preview-placeholder" id="previewPlaceholder">
                                <i class="fas fa-image"></i>
                                <p>Chọn ảnh từ máy tính</p>
                            </div>
                        </div>
                        <label class="form-label">Chọn ảnh món ăn</label>
                        <input type="file" name="imageFile" accept="image/*" class="form-control" id="imageFileInput" />
                        <input asp-for="ImageUrl" type="hidden" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <p style="font-size: 12px; color: var(--text-gray); margin-top: 6px;">Chấp nhận JPG, PNG, GIF. Kích thước tối đa 5MB.</p>
                    </div>
                    <div class="form-card">
                        <p class="form-section-title">Trạng thái bán</p>
                        <div class="toggle-row">
                            <div>
                                <div class="toggle-label">Đang bán</div>
                                <div class="toggle-sub">Món hiển thị cho sinh viên</div>
                            </div>
                            <label class="switch">
                                <input type="checkbox" asp-for="IsAvailable" checked />
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div style="display:flex; gap:12px;">
                        <button type="submit" class="btn-orange"><i class="fas fa-plus"></i> Thêm món ăn</button>
                        <a href="/CanteenDashboard/Foods" class="btn-ghost"><i class="fas fa-times"></i> Hủy bỏ</a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('imageFileInput')?.addEventListener('change', function () {
            const preview = document.getElementById('imagePreview');
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:12px;" alt="Preview">`;
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
