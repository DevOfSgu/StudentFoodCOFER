@model StudentFood.WebAdmin.Models.Food
@{
    Layout = null;
    ViewData["Title"] = "Xóa món ăn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - StudentFood COFER</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #F9F7F4;
            --bg-sidebar: #FAF8F5;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --primary-orange: #FF8A00;
            --primary-brown: #A05A19;
            --bg-card: #FFFFFF;
            --border-color: #EBE5DE;
            --success-green: #22C55E;
            --bg-hover: #EFEAE4;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 250px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 30px 24px;
            text-align: center;
        }

        .sidebar-header img {
            height: 120px;
            object-fit: contain;
            margin-bottom: 10px;
        }

        .sidebar-menu {
            padding: 10px 16px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            transition: color 0.2s;
        }

        .menu-item:hover {
            background-color: var(--bg-hover);
        }

        .menu-item.active {
            background-color: #EFE4D6;
            color: var(--text-dark);
        }

        .menu-item.active i {
            color: var(--text-dark);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
        }

        .user-profile {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 12px;
        }

        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info p {
            margin: 0;
            font-size: 12px;
            color: var(--text-gray);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 130px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .logout-btn i {
            margin-right: 10px;
        }

        .logout-btn:hover {
            color: var(--text-dark);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: 250px;
            padding: 30px 40px;
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding-top: 60px;
            background-color: #FAFAFA;
        }

        .delete-container {
            max-width: 540px;
            width: 100%;
        }

        .delete-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        .delete-card-top {
            padding: 32px 32px 24px;
            text-align: center;
        }

        .danger-icon {
            width: 72px;
            height: 72px;
            background: #FEE2E2;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .danger-icon i {
            font-size: 28px;
            color: #DC2626;
        }

        .delete-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 8px;
            color: #92400E;
        }

        .delete-subtitle {
            font-size: 14px;
            color: var(--text-gray);
            margin: 0;
        }

        .food-preview {
            margin: 0 32px 20px;
            border-radius: 14px;
            background: var(--bg-main);
            padding: 16px;
            display: flex;
            gap: 16px;
            align-items: center;
            border: 1.5px solid var(--border-color);
        }

        .food-preview-img {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            object-fit: cover;
            background: #EEE;
            flex-shrink: 0;
        }

        .food-preview-img-placeholder {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            background: var(--bg-hover);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: #B45309;
            font-size: 22px;
        }

        .food-preview-name {
            font-size: 16px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .food-preview-meta {
            font-size: 13px;
            color: var(--text-gray);
        }

        .food-preview-price {
            font-size: 17px;
            font-weight: 800;
            color: #B45309;
            margin-top: 4px;
        }

        .warning-box {
            margin: 0 32px 24px;
            background: #FFF7ED;
            border: 1.5px solid #FED7AA;
            border-radius: 14px;
            padding: 14px 16px;
            display: flex;
            gap: 10px;
            align-items: flex-start;
        }

        .warning-box i {
            color: #EA580C;
            margin-top: 2px;
            flex-shrink: 0;
        }

        .warning-box p {
            margin: 0;
            font-size: 13px;
            color: #9A3412;
            font-weight: 600;
        }

        .delete-actions {
            padding: 20px 32px 32px;
            display: flex;
            gap: 12px;
        }

        form.delete-form {
            display: contents;
        }

        .btn-danger-full {
            background: #DC2626;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 13px 0;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            flex: 1;
            transition: background 0.2s;
            font-family: inherit;
        }

        .btn-danger-full:hover {
            background: #B91C1C;
        }

        .btn-ghost {
            background: var(--bg-main);
            color: var(--text-dark);
            border: 1.5px solid var(--border-color);
            border-radius: 12px;
            padding: 13px 0;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            flex: 1;
            transition: all 0.2s;
        }

        .btn-ghost:hover {
            border-color: #B45309;
            color: #B45309;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header" style="text-align: center; padding: 20px 24px;">
            <img src="/logo.png" alt="Logo" style="height: 120px; object-fit: contain; margin-bottom: 10px;">
        </div>
        
        <div class="sidebar-menu">
            <a href="/CanteenDashboard" class="menu-item">
                <i class="fas fa-border-all"></i> Tổng quan
            </a>
            <a href="/CanteenDashboard/Foods" class="menu-item active">
                <i class="fas fa-utensils"></i> Quản lý Món ăn
            </a>
            <a href="/CanteenDashboard/Reviews" class="menu-item">
                <i class="fas fa-star"></i> Đánh giá
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="/img/avatar_canteen.png" alt="Canteen" class="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Canteen&background=FFF3E0&color=FF8A00'">
                <div class="user-info">
                    <h6>@Context.Session.GetString("UserName")</h6>
                    <p>@ViewBag.CanteenName</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="delete-container">
            <div class="delete-card">
                <div class="delete-card-top">
                    <div class="danger-icon">
                        <i class="fas fa-trash-alt"></i>
                    </div>
                    <h2 class="delete-title">Xác nhận xóa món ăn</h2>
                    <p class="delete-subtitle">Hành động này không thể hoàn tác. Món ăn sẽ bị xóa vĩnh viễn.</p>
                </div>

                <div class="food-preview">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="food-preview-img" alt="@Model.Name">
                    }
                    else
                    {
                        <div class="food-preview-img-placeholder"><i class="fas fa-utensils"></i></div>
                    }
                    <div>
                        <div class="food-preview-name">@Model.Name</div>
                        <div class="food-preview-meta">@(Model.Category?.Name ?? "—")</div>
                        <div class="food-preview-price">@Model.Price.ToString("N0")đ</div>
                    </div>
                </div>

                <div class="warning-box">
                    <i class="fas fa-exclamation-triangle"></i>
                    <p>Xóa món ăn sẽ ảnh hưởng đến lịch sử đơn hàng và dữ liệu liên quan. Hãy chắc chắn trước khi thực hiện.</p>
                </div>

                <div class="delete-actions">
                    <form asp-action="DeleteFood" class="delete-form">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn-danger-full">
                            <i class="fas fa-trash"></i> Xóa vĩnh viễn
                        </button>
                    </form>
                    <a href="/CanteenDashboard/Foods" class="btn-ghost">
                        <i class="fas fa-times"></i> Hủy bỏ
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
