@model List<StudentFood.WebAdmin.Models.Order>
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Đơn hàng";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg-main: #FDF9F3; --primary-orange: #FF8A00; --text-dark: #2A241F; --text-gray: #8A847E; --border-color: #F0EBE1; --bg-card: #FFFFFF; --bg-hover: #FFF3E0; }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }

        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); }
        .menu-item:hover, .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i, .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; }
        .logout-btn:hover { color: var(--text-dark); }

        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
        .page-title { font-size: 24px; font-weight: 800; margin: 0; }
        .page-subtitle { font-size: 13px; color: var(--text-gray); margin: 4px 0 0; }

        /* Stats Row */
        .stats-row { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
        .stat-chip { background: #fff; border-radius: 14px; padding: 14px 20px; flex: 1; min-width: 120px; box-shadow: 0 2px 12px rgba(0,0,0,0.03); cursor: pointer; border: 2px solid transparent; transition: all 0.2s; text-align: center; text-decoration: none; color: inherit; }
        .stat-chip:hover { border-color: var(--primary-orange); transform: translateY(-2px); }
        .stat-chip.active { border-color: var(--primary-orange); background: var(--bg-hover); }
        .stat-chip-value { font-size: 20px; font-weight: 800; }
        .stat-chip-label { font-size: 10px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.3px; margin-top: 2px; }

        /* Filter Bar */
        .filter-bar { background: #fff; border-radius: 16px; padding: 16px 20px; margin-bottom: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.03); display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .filter-input { border: 1.5px solid var(--border-color); border-radius: 10px; padding: 9px 14px; font-size: 13px; font-family: inherit; outline: none; transition: border-color 0.2s; }
        .filter-input:focus { border-color: var(--primary-orange); }
        .filter-input.search { flex: 1; min-width: 180px; padding-left: 36px; }
        .filter-input.date { width: 150px; }
        .search-wrap { position: relative; flex: 1; min-width: 180px; }
        .search-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-gray); font-size: 14px; }
        .search-wrap input { width: 100%; }
        .btn-filter { background: var(--primary-orange); color: #fff; border: none; border-radius: 10px; padding: 9px 18px; font-weight: 700; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s; font-family: inherit; }
        .btn-filter:hover { background: #e07a00; }

        /* Table Card */
        .section-card { background: #fff; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); overflow: hidden; }
        .table-responsive { overflow-x: auto; }
        table.orders-table { width: 100%; border-collapse: collapse; }
        table.orders-table thead tr { background: var(--bg-main); }
        table.orders-table th { padding: 12px 14px; font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid var(--border-color); white-space: nowrap; }
        table.orders-table td { padding: 13px 14px; font-size: 13px; font-weight: 500; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
        table.orders-table tr:last-child td { border-bottom: none; }
        table.orders-table tr:hover td { background: #FFFBF5; }

        .order-id-link { font-weight: 700; color: var(--primary-orange); text-decoration: none; }
        .order-id-link:hover { text-decoration: underline; }

        .badge-status { padding: 5px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; white-space: nowrap; display: inline-flex; align-items: center; gap: 4px; }
        .badge-pending { background: #FEF3C7; color: #92400E; }
        .badge-preparing { background: #DBEAFE; color: #1E40AF; }
        .badge-ready { background: #DCFCE7; color: #166534; }
        .badge-delivered { background: #D1FAE5; color: #065F46; }
        .badge-cancelled { background: #FEE2E2; color: #991B1B; }

        .student-avatar-sm { width: 28px; height: 28px; border-radius: 50%; background: #EFE4D6; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; color: #A05A19; margin-right: 8px; flex-shrink: 0; }

        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-state i { font-size: 48px; color: var(--border-color); margin-bottom: 16px; }
        .empty-state p { color: var(--text-gray); font-size: 15px; }

        .action-group { display: flex; gap: 4px; justify-content: flex-end; }
        .btn-icon-sm { width: 30px; height: 30px; border-radius: 6px; border: 1px solid var(--border-color); background: transparent; color: var(--text-dark); display: inline-flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.2s; font-size: 12px; }
        .btn-icon-sm:hover { background: var(--bg-hover); color: var(--primary-orange); border-color: var(--primary-orange); }

        /* ===== Responsive ===== */
        @@media (max-width: 1366px) {
            .main-content {
                padding: 24px 24px;
            }
            .stats-row {
                gap: 8px;
            }
            .stat-chip {
                padding: 10px 14px;
                min-width: 90px;
            }
            .stat-chip-value {
                font-size: 17px;
            }
        }

        @@media (max-width: 1200px) {
            .sidebar {
                width: 220px;
            }
            .main-content {
                margin-left: 220px;
                padding: 20px 20px;
            }
            .sidebar-header img {
                height: 60px;
            }
            .page-title {
                font-size: 20px;
            }
            table.orders-table th,
            table.orders-table td {
                padding: 10px 12px;
                font-size: 12px;
            }
            .filter-input.date {
                width: 130px;
            }
        }

        @@media (max-width: 992px) {
            .sidebar {
                width: 200px;
            }
            .main-content {
                margin-left: 200px;
                padding: 16px 16px;
            }
            .sidebar-header {
                padding: 16px;
            }
            .sidebar-menu {
                padding: 8px 12px;
            }
            .menu-item {
                padding: 10px 12px;
                font-size: 13px;
            }
            .sidebar-footer {
                padding: 16px;
            }
            .filter-bar {
                flex-direction: column;
                align-items: stretch;
            }
            .filter-input.date {
                width: 100%;
            }
        }

        @@media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
                flex-direction: row;
                flex-wrap: wrap;
                align-items: center;
                padding: 8px 16px;
            }
            .sidebar-header {
                padding: 4px 0;
            }
            .sidebar-header img {
                height: 40px;
            }
            .sidebar-menu {
                display: flex;
                gap: 4px;
                padding: 0;
                margin: 0 12px;
                flex-grow: 1;
            }
            .menu-item {
                padding: 6px 10px;
                font-size: 11px;
                margin-bottom: 0;
                white-space: nowrap;
            }
            .sidebar-footer {
                display: none;
            }
            .main-content {
                margin-left: 0;
                padding: 12px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
            }
            .page-title {
                font-size: 18px;
            }
            .stats-row {
                gap: 6px;
            }
            .stat-chip {
                min-width: 70px;
                padding: 8px 10px;
            }
            .stat-chip-value {
                font-size: 15px;
            }
            .stat-chip-label {
                font-size: 9px;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item active"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info"><h6>Quản trị viên</h6><p>Admin</p></div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <div>
                <h1 class="page-title">Quản lý Đơn hàng</h1>
                <p class="page-subtitle">Theo dõi và quản lý toàn bộ đơn hàng trong hệ thống</p>
            </div>
        </div>

        <!-- Stats chips -->
        <div class="stats-row" style="gap: 8px;">
            <a href="@Url.Action("Index", new { status = "all" })" class="stat-chip @(ViewBag.CurrentStatus == "all" ? "active" : "")">
                <div class="stat-chip-value" style="color: var(--text-dark);">@ViewBag.TotalOrders</div>
                <div class="stat-chip-label">Tất cả</div>
            </a>
            <a href="@Url.Action("Index", new { status = "pending" })" class="stat-chip @(ViewBag.CurrentStatus == "pending" ? "active" : "")">
                <div class="stat-chip-value" style="color: #92400E;">@ViewBag.PendingOrders</div>
                <div class="stat-chip-label">Chờ XN</div>
            </a>
            <a href="@Url.Action("Index", new { status = "preparing" })" class="stat-chip @(ViewBag.CurrentStatus == "preparing" ? "active" : "")">
                <div class="stat-chip-value" style="color: #1E40AF;">@ViewBag.PreparingOrders</div>
                <div class="stat-chip-label">Đang CB</div>
            </a>
            <a href="@Url.Action("Index", new { status = "ready" })" class="stat-chip @(ViewBag.CurrentStatus == "ready" ? "active" : "")">
                <div class="stat-chip-value" style="color: #166534;">@ViewBag.ReadyOrders</div>
                <div class="stat-chip-label">Sẵn sàng</div>
            </a>
            <a href="@Url.Action("Index", new { status = "delivered" })" class="stat-chip @(ViewBag.CurrentStatus == "delivered" ? "active" : "")">
                <div class="stat-chip-value" style="color: #065F46;">@ViewBag.DeliveredOrders</div>
                <div class="stat-chip-label">Đã giao</div>
            </a>
            <a href="@Url.Action("Index", new { status = "cancelled" })" class="stat-chip @(ViewBag.CurrentStatus == "cancelled" ? "active" : "")">
                <div class="stat-chip-value" style="color: #991B1B;">@ViewBag.CancelledOrders</div>
                <div class="stat-chip-label">Đã hủy</div>
            </a>
        </div>

        <!-- Filter Bar -->
        <form method="get" action="@Url.Action("Index")" class="filter-bar">
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <input type="text" name="search" class="filter-input search" placeholder="Tìm theo mã đơn, tên SV, căn tin..." value="@ViewBag.SearchTerm" />
            </div>
            <input type="date" name="dateFrom" class="filter-input date" value="@ViewBag.DateFrom" placeholder="Từ ngày" />
            <input type="date" name="dateTo" class="filter-input date" value="@ViewBag.DateTo" placeholder="Đến ngày" />
            <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
            <button type="submit" class="btn-filter"><i class="fas fa-search"></i> Lọc</button>
        </form>

        <!-- Orders Table -->
        <div class="section-card">
            <div class="table-responsive">
                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <i class="fas fa-shopping-cart"></i>
                        <p>Không có đơn hàng nào.</p>
                    </div>
                }
                else
                {
                    <table class="orders-table">
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Sinh viên</th>
                                <th>Căn tin</th>
                                <th>Tổng tiền</th>
                                <th>Thanh toán</th>
                                <th>Trạng thái</th>
                                <th>Ngày đặt</th>
                                <th style="text-align:right">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><a href="/Orders/Details/@order.Id" class="order-id-link">#ORD-@order.Id</a></td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="student-avatar-sm">
                                                @(order.Student?.FullName?.Substring(0, Math.Min(2, order.Student.FullName.Length)).ToUpper() ?? "??")
                                            </div>
                                            <div>
                                                <div style="font-weight: 600; font-size: 13px;">@(order.Student?.FullName ?? "—")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-weight: 600;">@(order.Canteen?.Name ?? "—")</td>
                                    <td style="font-weight: 700; color: var(--primary-orange);">@order.TotalPrice.ToString("N0")đ</td>
                                    <td>
                                        @if (order.PaymentMethod == "transfer")
                                        {
                                            <span style="color: #2563EB;"><i class="fas fa-university"></i> CK</span>
                                        }
                                        else
                                        {
                                            <span style="color: #16A34A;"><i class="fas fa-money-bill"></i> TM</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case "pending":
                                                <span class="badge-status badge-pending"><i class="fas fa-clock"></i> Chờ XN</span>
                                                break;
                                            case "preparing":
                                                <span class="badge-status badge-preparing"><i class="fas fa-fire"></i> Đang CB</span>
                                                break;
                                            case "ready":
                                                <span class="badge-status badge-ready"><i class="fas fa-check-circle"></i> Sẵn sàng</span>
                                                break;
                                            case "delivered":
                                                <span class="badge-status badge-delivered"><i class="fas fa-check-double"></i> Đã giao</span>
                                                break;
                                            case "cancelled":
                                                <span class="badge-status badge-cancelled"><i class="fas fa-ban"></i> Đã hủy</span>
                                                break;
                                            default:
                                                <span class="badge-status badge-pending">@order.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td style="color: var(--text-gray); font-size: 12px;">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div class="action-group">
                                            <a href="/Orders/Details/@order.Id" class="btn-icon-sm" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="padding: 16px 24px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 13px; color: var(--text-gray);">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
                </div>
                <div style="display: flex; gap: 6px;">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, search = ViewBag.SearchTerm, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, page = ViewBag.CurrentPage - 1 })" class="pagination-btn">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    @{
                        var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        var endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, search = ViewBag.SearchTerm, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, page = i })" class="pagination-btn @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, search = ViewBag.SearchTerm, dateFrom = ViewBag.DateFrom, dateTo = ViewBag.DateTo, page = ViewBag.CurrentPage + 1 })" class="pagination-btn">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</body>
</html>

<style>
    .pagination-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 10px;
        border: 1.5px solid var(--border-color); background: #fff;
        color: var(--text-dark); font-size: 13px; font-weight: 700;
        text-decoration: none; transition: all 0.2s;
    }
    .pagination-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
    .pagination-btn.active { background: var(--primary-orange); color: #fff; border-color: var(--primary-orange); }
</style>
