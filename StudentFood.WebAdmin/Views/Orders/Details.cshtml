@model StudentFood.WebAdmin.Models.Order
@{
    Layout = null;
    ViewData["Title"] = "Chi tiết đơn hàng #ORD-" + Model.Id;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg-main: #FDF9F3; --primary-orange: #FF8A00; --text-dark: #2A241F; --text-gray: #8A847E; --border-color: #F0EBE1; --bg-hover: #FFF3E0; }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }
        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); }
        .menu-item:hover, .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i, .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; }
        .logout-btn:hover { color: var(--text-dark); }
        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; }
        .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
        .back-btn { width: 40px; height: 40px; border-radius: 12px; background: #fff; border: 1.5px solid var(--border-color); display: flex; align-items: center; justify-content: center; color: var(--text-dark); text-decoration: none; transition: all 0.2s; }
        .back-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .page-title { font-size: 22px; font-weight: 800; margin: 0; }
        .page-subtitle { font-size: 13px; color: var(--text-gray); margin: 2px 0 0; }

        .section-card { background: #fff; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); padding: 28px; margin-bottom: 24px; }
        .section-title { font-size: 14px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border-color); }

        .status-badge-lg { padding: 8px 20px; border-radius: 30px; font-size: 14px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .info-item { background: var(--bg-main); border-radius: 12px; padding: 14px; }
        .info-item-label { font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
        .info-item-value { font-size: 14px; font-weight: 700; }

        .order-items-table { width: 100%; border-collapse: collapse; }
        .order-items-table th { text-align: left; padding: 10px 12px; font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; border-bottom: 1px solid var(--border-color); }
        .order-items-table td { padding: 12px; font-size: 13px; font-weight: 500; border-bottom: 1px solid var(--border-color); vertical-align: middle; }

        .food-img-sm { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; background: var(--bg-main); }

        .price-line { display: flex; justify-content: space-between; padding: 6px 0; font-size: 14px; }
        .price-line.total { font-weight: 800; font-size: 18px; color: var(--primary-orange); border-top: 2px solid var(--border-color); padding-top: 12px; margin-top: 6px; }

        .action-bar { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
        .btn-orange { background: var(--primary-orange); color: #fff; border: none; border-radius: 12px; padding: 10px 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s; font-family: inherit; text-decoration: none; }
        .btn-orange:hover { background: #e07a00; color: #fff; }
        .btn-ghost { background: var(--bg-main); color: var(--text-dark); border: 1.5px solid var(--border-color); border-radius: 12px; padding: 10px 20px; font-weight: 700; font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all 0.2s; }
        .btn-ghost:hover { border-color: var(--primary-orange); color: var(--primary-orange); }

        .review-card { background: var(--bg-main); border-radius: 12px; padding: 14px; margin-bottom: 12px; border: 1px solid var(--border-color); }
        .review-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .review-stars { color: #F59E0B; font-size: 13px; }

        /* ===== Responsive ===== */
        @media (max-width: 1366px) {
            .main-content { padding: 24px 24px; }
        }
        @media (max-width: 1200px) {
            .sidebar { width: 220px; }
            .main-content { margin-left: 220px; padding: 20px; }
            .sidebar-header img { height: 60px; }
            .page-title { font-size: 20px; }
        }
        @media (max-width: 992px) {
            .sidebar { width: 200px; }
            .main-content { margin-left: 200px; padding: 16px; }
            .sidebar-header { padding: 16px; }
            .sidebar-menu { padding: 8px 12px; }
            .menu-item { padding: 10px 12px; font-size: 13px; }
            .sidebar-footer { padding: 16px; }
            .page-header { flex-wrap: wrap; }
            .page-header > div:last-child { margin-left: 0 !important; width: 100%; }
            .info-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 768px) {
            .sidebar { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border-color); flex-direction: row; flex-wrap: wrap; align-items: center; padding: 8px 16px; }
            .sidebar-header { padding: 4px 0; }
            .sidebar-header img { height: 40px; }
            .sidebar-menu { display: flex; gap: 4px; padding: 0; margin: 0 12px; flex-grow: 1; }
            .menu-item { padding: 6px 10px; font-size: 11px; margin-bottom: 0; white-space: nowrap; }
            .sidebar-footer { display: none; }
            .main-content { margin-left: 0; padding: 12px; }
            .page-title { font-size: 18px; }
            .page-header > div:last-child { width: 100%; }
            .section-card { padding: 16px; }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item active"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info"><h6>Quản trị viên</h6><p>Admin</p></div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <a asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
            <div>
                <h1 class="page-title">Chi tiết đơn hàng #ORD-@Model.Id</h1>
                <p class="page-subtitle">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            <div style="margin-left:auto;">
                @switch (Model.Status)
                {
                    case "pending":
                        <span class="status-badge-lg" style="background:#FEF3C7;color:#92400E;"><i class="fas fa-clock"></i> Chờ xác nhận</span>
                        break;
                    case "preparing":
                        <span class="status-badge-lg" style="background:#DBEAFE;color:#1E40AF;"><i class="fas fa-fire"></i> Đang chuẩn bị</span>
                        break;
                    case "ready":
                        <span class="status-badge-lg" style="background:#DCFCE7;color:#166534;"><i class="fas fa-check-circle"></i> Sẵn sàng giao</span>
                        break;
                    case "delivered":
                        <span class="status-badge-lg" style="background:#D1FAE5;color:#065F46;"><i class="fas fa-check-double"></i> Đã giao hàng</span>
                        break;
                    case "cancelled":
                        <span class="status-badge-lg" style="background:#FEE2E2;color:#991B1B;"><i class="fas fa-ban"></i> Đã hủy</span>
                        break;
                }
            </div>
        </div>

        <div class="row g-4">
            <!-- Left: Thông tin đơn hàng -->
            <div class="col-lg-8">
                <!-- Thông tin sinh viên & căn tin -->
                <div class="section-card">
                    <div class="section-title">Thông tin đơn hàng</div>
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-item-label">Sinh viên</div>
                            <div class="info-item-value">@(Model.Student?.FullName ?? "—")</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label">Căn tin</div>
                            <div class="info-item-value">@(Model.Canteen?.Name ?? "—")</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label">Địa chỉ giao</div>
                            <div class="info-item-value" style="font-weight:500;">@(Model.DeliveryAddress ?? "—")</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label">Phương thức TT</div>
                            <div class="info-item-value">
                                @if (Model.PaymentMethod == "transfer")
                                {
                                    <span style="color:#2563EB;"><i class="fas fa-university"></i> Chuyển khoản</span>
                                }
                                else
                                {
                                    <span style="color:#16A34A;"><i class="fas fa-money-bill"></i> Tiền mặt</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Danh sách món -->
                <div class="section-card">
                    <div class="section-title">Món ăn trong đơn</div>
                    <table class="order-items-table">
                        <thead>
                            <tr>
                                <th>Món</th>
                                <th>Đơn giá</th>
                                <th style="text-align:center">SL</th>
                                <th style="text-align:right">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems ?? [])
                            {
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:10px;">
                                            @if (!string.IsNullOrEmpty(item.Food?.ImageUrl))
                                            {
                                                <img src="@item.Food.ImageUrl" class="food-img-sm" alt="" />
                                            }
                                            else
                                            {
                                                <div class="food-img-sm" style="background:var(--bg-hover);display:flex;align-items:center;justify-content:center;color:var(--text-gray);font-size:16px;">
                                                    <i class="fas fa-utensils"></i>
                                                </div>
                                            }
                                            <div>
                                                <div style="font-weight:700;">@(item.Food?.Name ?? "—")</div>
                                                @if (!string.IsNullOrEmpty(item.Note))
                                                {
                                                    <div style="font-size:11px;color:var(--text-gray);">📝 @item.Note</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-weight:600;">@item.PriceAtOrder.ToString("N0")đ</td>
                                    <td style="text-align:center;font-weight:700;">@item.Quantity</td>
                                    <td style="text-align:right;font-weight:700;color:var(--primary-orange);">@((item.PriceAtOrder * item.Quantity).ToString("N0"))đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div style="margin-top:20px;max-width:320px;margin-left:auto;">
                        <div class="price-line"><span>Tạm tính</span><span>@Model.Subtotal.ToString("N0")đ</span></div>
                        <div class="price-line"><span>Phí giao hàng</span><span>@Model.DeliveryFee.ToString("N0")đ</span></div>
                        <div class="price-line total"><span>Tổng cộng</span><span>@Model.TotalPrice.ToString("N0")đ</span></div>
                    </div>
                </div>

                <!-- Reviews (nếu có) -->
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    <div class="section-card">
                        <div class="section-title">Đánh giá từ sinh viên</div>
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-card">
                                <div class="review-header">
                                    <div style="font-weight:700;font-size:13px;">@review.Student?.FullName</div>
                                    <div class="review-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-star" style="color:#DDD;"></i>
                                            }
                                        }
                                    </div>
                                </div>
                                <div style="font-size:12px;color:var(--text-gray);margin-bottom:6px;">
                                    <i class="far fa-clock"></i> @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p style="font-size:13px;margin:0;color:#5B5147;">@review.Comment</p>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Right: Timeline & Actions -->
            <div class="col-lg-4">
                <div class="section-card">
                    <div class="section-title">Cập nhật trạng thái</div>
                    <p style="font-size:13px;color:var(--text-gray);margin-bottom:16px;">
                        Cập nhật trạng thái đơn hàng thủ công (admin)
                    </p>

                    <form method="post" action="/Orders/UpdateStatus" style="margin-bottom:12px;">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="status" value="preparing" />
                        <button type="submit" class="btn-orange" style="width:100%;justify-content:center;@(Model.Status != "pending" ? "opacity:0.5;pointer-events:none;" : "")">
                            <i class="fas fa-fire"></i> Xác nhận - Đang nấu
                        </button>
                    </form>

                    <form method="post" action="/Orders/UpdateStatus" style="margin-bottom:12px;">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="status" value="ready" />
                        <button type="submit" class="btn-orange" style="width:100%;justify-content:center;background:#16A34A;@(Model.Status != "preparing" ? "opacity:0.5;pointer-events:none;" : "")">
                            <i class="fas fa-check"></i> Đánh dấu đã nấu xong
                        </button>
                    </form>

                    <form method="post" action="/Orders/UpdateStatus" style="margin-bottom:12px;">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="status" value="delivered" />
                        <button type="submit" class="btn-orange" style="width:100%;justify-content:center;background:#065F46;@(Model.Status != "ready" ? "opacity:0.5;pointer-events:none;" : "")">
                            <i class="fas fa-check-double"></i> Xác nhận đã giao
                        </button>
                    </form>

                    @if (Model.Status == "pending" || Model.Status == "preparing")
                    {
                        <form method="post" action="/Orders/UpdateStatus">
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <input type="hidden" name="status" value="cancelled" />
                            <button type="submit" class="btn-ghost" style="width:100%;justify-content:center;color:#DC2626;border-color:#FCA5A5;">
                                <i class="fas fa-ban"></i> Hủy đơn hàng
                            </button>
                        </form>
                    }
                </div>

                <div class="section-card">
                    <div class="section-title">Dòng thời gian</div>
                    <div style="position:relative;padding-left:20px;">
                        <div style="position:absolute;left:6px;top:4px;bottom:0;width:2px;background:var(--border-color);"></div>

                        <div style="position:relative;margin-bottom:16px;">
                            <div style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:var(--primary-orange);border:2px solid #fff;"></div>
                            <div style="font-size:12px;color:var(--text-gray);">Đặt hàng</div>
                            <div style="font-weight:700;font-size:13px;">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        @if (Model.Status == "preparing" || Model.Status == "ready" || Model.Status == "delivered")
                        {
                            <div style="position:relative;margin-bottom:16px;">
                                <div style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:#1E40AF;border:2px solid #fff;"></div>
                                <div style="font-size:12px;color:var(--text-gray);">Đang chuẩn bị</div>
                                <div style="font-weight:700;font-size:13px;">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        }

                        @if (Model.Status == "ready" || Model.Status == "delivered")
                        {
                            <div style="position:relative;margin-bottom:16px;">
                                <div style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:#166534;border:2px solid #fff;"></div>
                                <div style="font-size:12px;color:var(--text-gray);">Sẵn sàng giao</div>
                                <div style="font-weight:700;font-size:13px;">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        }

                        @if (Model.Status == "delivered")
                        {
                            <div style="position:relative;">
                                <div style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:#065F46;border:2px solid #fff;"></div>
                                <div style="font-size:12px;color:var(--text-gray);">Đã giao hàng</div>
                                <div style="font-weight:700;font-size:13px;">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        }

                        @if (Model.Status == "cancelled")
                        {
                            <div style="position:relative;">
                                <div style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:#DC2626;border:2px solid #fff;"></div>
                                <div style="font-size:12px;color:var(--text-gray);">Đã hủy</div>
                                <div style="font-weight:700;font-size:13px;">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                @if (!string.IsNullOrEmpty(Model.CancelReason))
                                {
                                    <div style="font-size:12px;color:#DC2626;margin-top:4px;">Lý do: @Model.CancelReason</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
