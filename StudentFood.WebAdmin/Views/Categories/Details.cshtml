@model StudentFood.WebAdmin.Models.Category
@{
    Layout = null;
    ViewData["Title"] = "Chi tiết danh mục";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg-main: #FDF9F3; --primary-orange: #FF8A00; --text-dark: #2A241F; --text-gray: #8A847E; --border-color: #F0EBE1; --bg-hover: #FFF3E0; }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }
        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); }
        .menu-item:hover, .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i, .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; }
        .logout-btn:hover { color: var(--text-dark); }
        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; }
        .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; }
        .back-btn { width: 40px; height: 40px; border-radius: 12px; background: #fff; border: 1.5px solid var(--border-color); display: flex; align-items: center; justify-content: center; color: var(--text-dark); text-decoration: none; transition: all 0.2s; }
        .back-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .page-title { font-size: 22px; font-weight: 800; margin: 0; }
        .page-subtitle { font-size: 13px; color: var(--text-gray); margin: 2px 0 0; }
        .detail-card { background: #fff; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); overflow: hidden; max-width: 560px; }
        .detail-body { padding: 32px; }
        .cat-hero { display: flex; align-items: center; gap: 24px; padding: 32px; background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
        .cat-icon-huge { width: 80px; height: 80px; border-radius: 20px; background: rgba(255,255,255,0.7); display: flex; align-items: center; justify-content: center; color: var(--primary-orange); font-size: 36px; flex-shrink: 0; }
        .cat-name-huge { font-size: 26px; font-weight: 800; margin: 0 0 4px; }
        .cat-icon-detail { font-size: 13px; color: #9A6B3A; }
        .info-section { padding: 0 32px 24px; }
        .section-title { font-size: 14px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border-color); }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .info-item { background: var(--bg-main); border-radius: 14px; padding: 16px; }
        .info-item-label { font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
        .info-item-value { font-size: 15px; font-weight: 700; color: var(--text-dark); }
        .action-bar { padding: 0 32px 32px; display: flex; gap: 12px; }
        .btn-orange { background: var(--primary-orange); color: #fff; border: none; border-radius: 12px; padding: 12px 24px; font-weight: 700; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; transition: background 0.2s; font-family: inherit; }
        .btn-orange:hover { background: #e07a00; color: #fff; }
        .btn-ghost { background: var(--bg-main); color: var(--text-dark); border: 1.5px solid var(--border-color); border-radius: 12px; padding: 12px 24px; font-weight: 700; font-size: 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s; }
        .btn-ghost:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .btn-danger-soft { background: #FEE2E2; color: #DC2626; border: none; border-radius: 12px; padding: 12px 24px; font-weight: 700; font-size: 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s; }
        .btn-danger-soft:hover { background: #FECACA; color: #B91C1C; }

        @media (max-width: 1366px) { .main-content { padding: 24px; } }
        @media (max-width: 1200px) { .sidebar { width: 220px; } .main-content { margin-left: 220px; padding: 20px; } .sidebar-header img { height: 60px; } .page-title { font-size: 20px; } }
        @media (max-width: 992px) { .sidebar { width: 200px; } .main-content { margin-left: 200px; padding: 16px; } .sidebar-header { padding: 16px; } .sidebar-menu { padding: 8px 12px; } .menu-item { padding: 10px 12px; font-size: 13px; } .sidebar-footer { padding: 16px; } .info-grid { grid-template-columns: 1fr; } .cat-hero { flex-direction: column; align-items: flex-start; gap: 16px; } .action-bar { flex-wrap: wrap; } }
        @media (max-width: 768px) { .sidebar { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border-color); flex-direction: row; flex-wrap: wrap; align-items: center; padding: 8px 16px; } .sidebar-header { padding: 4px 0; } .sidebar-header img { height: 40px; } .sidebar-menu { display: flex; gap: 4px; padding: 0; margin: 0 12px; flex-grow: 1; } .menu-item { padding: 6px 10px; font-size: 11px; margin-bottom: 0; white-space: nowrap; } .sidebar-footer { display: none; } .main-content { margin-left: 0; padding: 12px; } .page-title { font-size: 18px; } .cat-hero { padding: 20px; } .detail-body { padding: 20px; } .info-section { padding: 0 20px 16px; } .action-bar { padding: 0 20px 24px; } }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info"><h6>Quản trị viên</h6><p>Admin</p></div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <a asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
            <div>
                <h1 class="page-title">Chi tiết danh mục</h1>
                <p class="page-subtitle">ID: #@Model.Id</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="detail-card">
                    <div class="cat-hero">
                        <div class="cat-icon-huge">
                            <i class="fas fa-@(string.IsNullOrEmpty(Model.IconUrl) ? "tag" : Model.IconUrl)"></i>
                        </div>
                        <div>
                            <h2 class="cat-name-huge">@Model.Name</h2>
                            <div class="cat-icon-detail"><i class="fas fa-icons"></i> Icon: @(Model.IconUrl ?? "mặc định")</div>
                        </div>
                    </div>

                    <div class="info-section">
                        <div class="section-title">Thông tin</div>
                        <div class="info-grid">
                            <div class="info-item">
                                <div class="info-item-label">ID</div>
                                <div class="info-item-value">#@Model.Id</div>
                            </div>
                            <div class="info-item">
                                <div class="info-item-label">Tên danh mục</div>
                                <div class="info-item-value">@Model.Name</div>
                            </div>
                            <div class="info-item">
                                <div class="info-item-label">Icon URL</div>
                                <div class="info-item-value" style="font-size:13px; color: var(--text-gray); font-weight:500;">@(Model.IconUrl ?? "—")</div>
                            </div>
                        </div>
                    </div>

                    <div class="action-bar">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-orange">
                            <i class="fas fa-pen"></i> Chỉnh sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-danger-soft">
                            <i class="fas fa-trash"></i> Xóa
                        </a>
                        <a asp-action="Index" class="btn-ghost">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
