@model IEnumerable<StudentFood.WebAdmin.Models.Category>
@{
    Layout = null;
    ViewData["Title"] = "Quản lý Danh mục";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg-main: #FDF9F3; --primary-orange: #FF8A00; --text-dark: #2A241F; --text-gray: #8A847E; --border-color: #F0EBE1; --bg-card: #FFFFFF; --bg-hover: #FFF3E0; }
        * { box-sizing: border-box; }
        body { background: var(--bg-main); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text-dark); margin: 0; }

        .sidebar { width: 250px; background: #fff; height: 100vh; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-header { padding: 20px 24px; text-align: center; }
        .sidebar-header img { height: 80px; object-fit: contain; }
        .sidebar-menu { padding: 10px 16px; flex-grow: 1; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 11px 16px; color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s; }
        .menu-item i { width: 20px; color: var(--text-gray); }
        .menu-item:hover, .menu-item.active { background: var(--bg-hover); color: var(--primary-orange); }
        .menu-item:hover i, .menu-item.active i { color: var(--primary-orange); }
        .sidebar-footer { padding: 20px 24px; border-top: 1px solid var(--border-color); }
        .user-profile { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .user-avatar-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
        .user-info h6 { margin: 0; font-weight: 700; font-size: 13px; }
        .user-info p { margin: 0; font-size: 11px; color: var(--text-gray); }
        .logout-btn { display: flex; align-items: center; gap: 8px; color: var(--text-gray); text-decoration: none; font-size: 13px; font-weight: 600; }
        .logout-btn:hover { color: var(--text-dark); }

        .main-content { margin-left: 250px; padding: 32px 40px; min-height: 100vh; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
        .page-title { font-size: 24px; font-weight: 800; margin: 0; }
        .page-subtitle { font-size: 13px; color: var(--text-gray); margin: 4px 0 0; }

        .btn-orange { background: var(--primary-orange); color: #fff; border: none; border-radius: 12px; padding: 10px 20px; font-weight: 700; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; transition: background 0.2s; }
        .btn-orange:hover { background: #e07a00; color: #fff; }

        .section-card { background: var(--bg-card); border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); overflow: hidden; }
        .section-card-header { padding: 20px 24px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; }
        .section-card-title { font-size: 16px; font-weight: 700; margin: 0; }

        .stats-row { display: flex; gap: 16px; margin-bottom: 24px; }
        .stat-mini { background: #fff; border-radius: 16px; padding: 18px 22px; flex: 1; box-shadow: 0 2px 12px rgba(0,0,0,0.03); }
        .stat-mini-label { font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
        .stat-mini-value { font-size: 22px; font-weight: 800; }

        .table-custom { width: 100%; border-collapse: collapse; }
        .table-custom th { text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 700; color: var(--text-gray); text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid var(--border-color); white-space: nowrap; }
        .table-custom td { padding: 14px 16px; font-size: 14px; font-weight: 500; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
        .table-custom tr:last-child td { border-bottom: none; }
        .table-custom tr:hover td { background: #FFFBF5; }

        .icon-badge { width: 44px; height: 44px; border-radius: 12px; background: var(--bg-hover); display: flex; align-items: center; justify-content: center; color: var(--primary-orange); font-size: 20px; }
        .cat-name { font-weight: 700; font-size: 15px; }

        .btn-action-icon { width: 34px; height: 34px; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-dark); display: inline-flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.2s; margin-left: 4px; }
        .btn-action-icon:hover { background: var(--bg-hover); color: var(--primary-orange); border-color: var(--primary-orange); }
        .btn-action-icon.danger:hover { background: #FEE2E2; color: #DC2626; border-color: #DC2626; }

        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-state i { font-size: 48px; color: var(--border-color); margin-bottom: 16px; }
        .empty-state p { color: var(--text-gray); font-size: 15px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/logo.png" alt="Logo" onerror="this.style.display='none'">
        </div>
        <div class="sidebar-menu">
            <a href="/Dashboard" class="menu-item"><i class="fas fa-border-all"></i> Tổng quan</a>
            <a href="/Orders" class="menu-item"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <a href="/Canteens" class="menu-item"><i class="fas fa-store"></i> Đối tác</a>
        </div>
        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19" alt="Admin" class="user-avatar-img">
                <div class="user-info"><h6>Quản trị viên</h6><p>Admin</p></div>
            </div>
            <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <div>
                <h1 class="page-title">Quản lý Danh mục</h1>
                <p class="page-subtitle">Quản lý danh mục món ăn trong hệ thống</p>
            </div>
            <a asp-action="Create" class="btn-orange">
                <i class="fas fa-plus"></i> Thêm danh mục
            </a>
        </div>

        @{
            var totalCats = Model.Count();
        }
        <div class="stats-row">
            <div class="stat-mini">
                <div class="stat-mini-label">Tổng danh mục</div>
                <div class="stat-mini-value">@totalCats</div>
            </div>
        </div>

        <div class="section-card">
            <div class="section-card-header">
                <h2 class="section-card-title">Danh sách danh mục</h2>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-tags"></i>
                    <p>Chưa có danh mục nào. <a asp-action="Create" style="color: var(--primary-orange); font-weight: 700;">Thêm ngay!</a></p>
                </div>
            }
            else
            {
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Danh mục</th>
                            <th>Icon</th>
                            <th style="text-align:right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="color: var(--text-gray); font-size: 13px; font-weight: 600;">@item.Id</td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:12px;">
                                        <div class="icon-badge">
                                            <i class="fas fa-@(string.IsNullOrEmpty(item.IconUrl) ? "tag" : item.IconUrl)"></i>
                                        </div>
                                        <div class="cat-name">@item.Name</div>
                                    </div>
                                </td>
                                <td style="color: var(--text-gray); font-size: 13px;">@(item.IconUrl ?? "—")</td>
                                <td>
                                    <div class="d-flex justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon" title="Sửa"><i class="fas fa-pen"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action-icon" title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon danger" title="Xóa"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="padding: 16px 24px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 13px; color: var(--text-gray);">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
                </div>
                <div style="display: flex; gap: 6px;">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1 })" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
                    }
                    @{
                        var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        var endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);
                    }
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a href="@Url.Action("Index", new { page = i })" class="pagination-btn @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1 })" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
                    }
                </div>
            </div>
        }
    </div>

    <style>
        .pagination-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 10px;
            border: 1.5px solid var(--border-color); background: #fff;
            color: var(--text-dark); font-size: 13px; font-weight: 700;
            text-decoration: none; transition: all 0.2s;
        }
        .pagination-btn:hover { border-color: var(--primary-orange); color: var(--primary-orange); }
        .pagination-btn.active { background: var(--primary-orange); color: #fff; border-color: var(--primary-orange); }
    </style>
</body>
</html>
