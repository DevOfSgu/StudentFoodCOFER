@model List<StudentFood.WebAdmin.Models.Order>
@{
    Layout = null;
    ViewData["Title"] = "Admin Panel";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #FDF9F3;
            --bg-sidebar: #FFFFFF;
            --text-dark: #2A241F;
            --text-gray: #8A847E;
            --primary-orange: #FF8A00;
            --primary-brown: #FF8A00; /* Thay màu nâu thành cam đồng bộ */
            --bg-card: #FFFFFF;
            --border-color: #F0EBE1;
            --success-green: #22C55E;
            --bg-hover: #FFF3E0;
        }

        body {
            background-color: var(--bg-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            margin: 0;
            padding: 0;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 250px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 30px 24px;
        }

        .sidebar-title {
            color: var(--primary-brown);
            font-weight: 800;
            font-size: 20px;
            margin: 0;
            line-height: 1.2;
        }

        .sidebar-subtitle {
            color: var(--text-gray);
            font-size: 12px;
            font-weight: 500;
            margin: 0;
        }

        .sidebar-menu {
            padding: 10px 16px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            color: var(--text-gray);
            transition: color 0.2s;
        }

        .menu-item:hover {
            background-color: var(--bg-hover);
        }

        .menu-item.active {
            background-color: var(--bg-hover);
            color: var(--primary-orange);
        }

        .menu-item.active i {
            color: var(--primary-orange);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
        }

        .user-profile {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 12px;
        }

        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info p {
            margin: 0;
            font-size: 12px;
            color: var(--text-gray);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .logout-btn i {
            margin-right: 10px;
        }

        .logout-btn:hover {
            color: var(--text-dark);
        }

        /* --- Main Content --- */
        .main-content {
            margin-left: 250px;
            padding: 30px 40px;
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .search-bar {
            position: relative;
        }

        .search-bar i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-gray);
        }

        .search-bar input {
            background-color: var(--bg-hover);
            border: none;
            border-radius: 20px;
            padding: 10px 16px 10px 40px;
            width: 250px;
            font-size: 14px;
            outline: none;
        }

        .icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: transparent;
            border: none;
            color: var(--text-dark);
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .icon-btn:hover {
            background-color: var(--bg-hover);
        }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-bottom: 24px;
        }

        .btn-custom {
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-gray {
            background-color: var(--bg-hover);
            color: var(--text-dark);
        }

        .btn-gray:hover {
            background-color: #E2DBD4;
        }

        .btn-brown {
            background-color: var(--primary-brown);
            color: white;
        }

        .btn-brown:hover {
            background-color: #8C4E15;
        }

        /* Cards */
        .stat-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .stat-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0;
        }

        .stat-icon-small {
            color: var(--primary-brown);
            font-size: 16px;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .stat-meta {
            font-size: 13px;
            font-weight: 600;
        }

        .text-success { color: var(--success-green) !important; }
        .text-danger { color: #EF4444 !important; }
        .text-gray { color: var(--text-gray) !important; }

        /* Chart Section */
        .section-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            margin-bottom: 24px;
            height: 100%;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .section-subtitle {
            font-size: 13px;
            color: var(--text-gray);
            margin: 0;
        }

        .filter-group {
            background: var(--bg-main);
            border-radius: 8px;
            display: flex;
            padding: 4px;
        }

        .filter-btn {
            background: transparent;
            border: none;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 600;
            border-radius: 6px;
            color: var(--text-gray);
        }

        .filter-btn.active {
            background: var(--bg-card);
            color: var(--text-dark);
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        /* Mock Chart */
        .mock-chart {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            height: 200px;
            padding-top: 20px;
        }

        .bar-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 10%;
        }

        .bar {
            width: 100%;
            background-color: #FBEBDD;
            border-radius: 6px 6px 0 0;
            transition: all 0.3s;
        }

        .bar.active {
            background-color: var(--primary-orange);
            position: relative;
        }

        .bar.active::after {
            content: attr(data-val);
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--text-dark);
            color: white;
            font-size: 11px;
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: 600;
        }

        .bar-label {
            margin-top: 12px;
            font-size: 12px;
            color: var(--text-gray);
            font-weight: 500;
        }

        /* Trending Orders */
        .trending-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .trending-item {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .trending-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--bg-main);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-brown);
            margin-right: 16px;
        }

        .trending-info {
            flex-grow: 1;
        }

        .trending-name {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .progress-bar-bg {
            height: 6px;
            background: var(--bg-main);
            border-radius: 3px;
            width: 100%;
        }

        .progress-bar-fill {
            height: 100%;
            background: var(--primary-brown);
            border-radius: 3px;
        }

        .trending-percent {
            font-size: 13px;
            font-weight: 700;
            width: 40px;
            text-align: right;
        }

        /* Tables & Lists */
        .table-custom {
            width: 100%;
            border-collapse: collapse;
        }

        .table-custom th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-gray);
            text-transform: uppercase;
            border-bottom: 1px solid var(--border-color);
        }

        .table-custom td {
            padding: 16px;
            font-size: 14px;
            font-weight: 600;
            border-bottom: 1px solid var(--border-color);
        }

        .table-custom tr:last-child td {
            border-bottom: none;
        }

        .badge-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        
        .badge-delivered { background: #D1FAE5; color: #166534; }
        .badge-pending { background: #FEF3C7; color: #92400E; }
        
        .view-all {
            color: var(--primary-brown);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
        }

        /* Feedback */
        .feedback-item {
            display: flex;
            padding: 16px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .feedback-item:last-child {
            border-bottom: none;
        }

        .feedback-avatar {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            margin-right: 16px;
            object-fit: cover;
        }

        .feedback-content h6 {
            margin: 0 0 4px 0;
            font-size: 14px;
            font-weight: 700;
        }

        .feedback-meta {
            font-size: 12px;
            color: var(--text-gray);
            margin: 0;
        }

        .feedback-stars {
            color: var(--primary-orange);
            font-size: 12px;
            margin-left: auto;
        }

        /* Helpers */
        .student-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #EFE4D6;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            color: var(--primary-brown);
            margin-right: 8px;
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header" style="text-align: center; padding: 20px 24px;">
            <img src="/logo.png" alt="Logo" style="height: 120px; object-fit: contain; margin-bottom: 10px;">
        </div>
        
        <div class="sidebar-menu">
            <a href="#" class="menu-item active">
                <i class="fas fa-border-all"></i> Tổng quan
            </a>
            <a href="/Orders" class="menu-item">
                <i class="fas fa-shopping-cart"></i> Đơn hàng
            </a>
            <a href="/Analytics" class="menu-item">
                <i class="fas fa-chart-bar"></i> Thống kê
            </a>
            <a href="/Reviews" class="menu-item">
                <i class="fas fa-comment-alt"></i> Đánh giá
            </a>
            <a href="/Canteens" class="menu-item">
                <i class="fas fa-users"></i> Nhân viên
            </a>
            <a href="/Settings" class="menu-item">
                <i class="fas fa-cog"></i> Cài đặt
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-profile">
                <img src="/img/avatar_admin.png" alt="Admin" class="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Admin&background=EFE4D6&color=A05A19'">
                <div class="user-info">
                    <h6>@Context.Session.GetString("UserName")</h6>
                    <p>Quản trị viên</p>
                </div>
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <h2 class="page-title">Chào mừng trở lại, Quản trị viên.</h2>
            <div class="top-actions">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Tìm kiếm dữ liệu...">
                </div>
                <button class="icon-btn"><i class="far fa-bell"></i></button>
                <button class="icon-btn"><i class="far fa-question-circle"></i></button>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
            <button class="btn-custom btn-gray">
                <i class="fas fa-user-plus"></i> Quản lý nhân viên
            </button>
            <button class="btn-custom btn-brown">
                <i class="far fa-eye"></i> Xem đơn hàng
            </button>
        </div>

        <!-- 5 Stat Cards (as in image) -->
        <div class="row g-4 mb-4">
            <div class="col">
                <div class="stat-card">
                    <div class="stat-header">
                        <h3 class="stat-title">ĐƠN HÀNG<br>HÔM NAY</h3>
                        <i class="fas fa-shopping-bag stat-icon-small" style="color: #A05A19;"></i>
                    </div>
                    <div class="stat-value">@ViewBag.OrdersToday.ToString("N0")</div>
                </div>
            </div>
            
            <div class="col">
                <div class="stat-card">
                    <div class="stat-header">
                        <h3 class="stat-title">DOANH THU<br>HÔM NAY</h3>
                        <i class="fas fa-money-bill-wave stat-icon-small" style="color: #22C55E;"></i>
                    </div>
                    <div class="stat-value">@string.Format("{0:N0}đ", ViewBag.RevenueToday)</div>
                </div>
            </div>

            <div class="col">
                <div class="stat-card">
                    <div class="stat-header">
                        <h3 class="stat-title">HOA HỒNG</h3>
                        <i class="fas fa-wallet stat-icon-small" style="color: #FFB020;"></i>
                    </div>
                    <div class="stat-value">@string.Format("{0:N0}đ", ViewBag.CommissionToday)</div>
                </div>
            </div>

            <div class="col">
                <div class="stat-card">
                    <div class="stat-header">
                        <h3 class="stat-title">SINH VIÊN</h3>
                        <i class="far fa-user stat-icon-small" style="color: #A05A19;"></i>
                    </div>
                    <div class="stat-value">@ViewBag.TotalStudents.ToString("N0")</div>
                </div>
            </div>

            <div class="col">
                <div class="stat-card">
                    <div class="stat-header">
                        <h3 class="stat-title">ĐÁNH GIÁ<br>TRUNG BÌNH</h3>
                        <i class="far fa-star stat-icon-small" style="color: #FFB020;"></i>
                    </div>
                    <div class="stat-value">@ViewBag.AvgRating.ToString("0.0")/5</div>
                    <div class="stat-meta text-warning mt-2">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Middle Section -->
        <div class="row g-4 mb-4">
            <div class="col-md-8">
                <div class="section-card">
                    <div class="section-header">
                        <div>
                            <h3 class="section-title">Biểu đồ doanh thu</h3>
                            <p class="section-subtitle">Tổng khối lượng giao dịch trên toàn hệ thống.</p>
                        </div>
                        <div class="filter-group">
                            <button class="filter-btn active">7 Ngày qua</button>
                        </div>
                    </div>
                    
                    <div class="mock-chart">
                        @{
                            var chartData = ViewBag.ChartData as List<decimal>;
                            var labels = ViewBag.ChartLabels as List<string>;
                            var maxVal = chartData != null && chartData.Any() ? chartData.Max() : 1;
                            if(maxVal == 0) maxVal = 1;
                        }
                        
                        @if(chartData != null)
                        {
                            for(int i = 0; i < chartData.Count; i++)
                            {
                                var height = (chartData[i] * 100 / maxVal);
                                if(height < 10) height = 10;
                                var isActive = i == chartData.Count - 1 ? "active" : ""; // Make today active
                                var formatVal = chartData[i] >= 1000000 ? (chartData[i]/1000000).ToString("0.##") + "M" : (chartData[i]/1000).ToString("0") + "k";
                                
                                <div class="bar-wrapper">
                                    @if(isActive == "active")
                                    {
                                        <div class="bar @isActive" style="height: @height%;" data-val="@formatVal"></div>
                                    }
                                    else
                                    {
                                        <div class="bar @isActive" style="height: @height%;"></div>
                                    }
                                    <div class="bar-label">@labels[i]</div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="section-card">
                    <h3 class="section-title mb-4">Món ăn thịnh hành</h3>
                    
                    <ul class="trending-list">
                        @foreach(var item in ViewBag.TrendingOrders as List<StudentFood.WebAdmin.Models.TrendingOrderDto>)
                        {
                            <li class="trending-item">
                                <div class="trending-icon" style="padding: 0; overflow: hidden; background: #eee;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" style="width: 100%; height: 100%; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <i class="fas fa-hamburger"></i>
                                    }
                                </div>
                                <div class="trending-info">
                                    <div class="trending-name">@item.Name</div>
                                    <div class="progress-bar-bg">
                                        <div class="progress-bar-fill" style="width: @item.Percentage%;"></div>
                                    </div>
                                </div>
                                <div class="trending-percent">@item.Percentage%</div>
                            </li>
                        }
                    </ul>
                    
                    <button class="btn btn-outline-secondary w-100 mt-3" style="border-radius: 8px; font-weight: 600; font-size: 13px;">
                        Xuất báo cáo
                    </button>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="row g-4">
            <div class="col-md-7">
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Đơn hàng mới nhất</h3>
                        <a href="/Orders" class="view-all">Xem tất cả</a>
                    </div>
                    
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>MÃ ĐƠN</th>
                                <th>SINH VIÊN</th>
                                <th>TỔNG TIỀN</th>
                                <th>TRẠNG THÁI</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var order in Model)
                            {
                                <tr>
                                    <td>#ORD-@order.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="student-avatar">@order.Student.FullName.Substring(0,2).ToUpper()</div>
                                            @order.Student.FullName
                                        </div>
                                    </td>
                                    <td>@string.Format("{0:N0}đ", order.TotalPrice)</td>
                                    <td>
                                        @if(order.Status == "delivered")
                                        {
                                            <span class="badge-status badge-delivered">Đã giao</span>
                                        }
                                        else if(order.Status == "ready")
                                        {
                                            <span class="badge-status badge-ready" style="background: #DCFCE7; color: #166534;">Sẵn sàng</span>
                                        }
                                        else if(order.Status == "preparing")
                                        {
                                            <span class="badge-status badge-preparing" style="background: #DBEAFE; color: #1E40AF;">Đang chuẩn bị</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status badge-pending">Chờ xử lý</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="col-md-5">
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Đánh giá gần đây</h3>
                        <a href="/Reviews" class="view-all">Xem tất cả</a>
                    </div>
                    
                    <div>
                        @foreach(var review in ViewBag.RecentFeedback)
                        {
                            <div class="feedback-item">
                                <div style="position: relative; margin-right: 16px;">
                                    <img src="@review.Student.AvatarUrl" onerror="this.src='https://ui-avatars.com/api/?name=@review.Student.FullName&background=random'" class="feedback-avatar" alt="" style="border: 2px solid white; position: relative; z-index: 2;">
                                    @if (!string.IsNullOrEmpty(review.Food.ImageUrl))
                                    {
                                        <img src="@review.Food.ImageUrl" alt="" style="width: 24px; height: 24px; border-radius: 4px; position: absolute; bottom: -5px; right: -5px; z-index: 3; border: 1px solid #ddd; object-fit: cover;">
                                    }
                                </div>
                                <div class="feedback-content">
                                    <h6>@review.Student.FullName</h6>
                                    <p class="feedback-meta">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm") • @review.Food.Name</p>
                                </div>
                                <div class="feedback-stars">
                                    @for(int i=0; i<review.Rating; i++){ <i class="fas fa-star"></i> }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
