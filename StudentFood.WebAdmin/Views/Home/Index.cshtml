@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StudentFood COFER - Đặt Đồ Ăn Căn Tin Tiện Lợi</title>
    
    <!-- Google Fonts: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* Modern Design System & Variables */
        :root {
            --primary: #FF8A00;
            --primary-hover: #E07A00;
            --primary-light: #FFF3E0;
            --dark: #222222;
            --light: #F7F7F7;
            --white: #FFFFFF;
            --gray: #666666;
            --gray-light: #EAEAEA;
            --success: #2ECC71;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            --shadow-hover: 0 15px 35px rgba(255, 138, 0, 0.15);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --border-radius: 16px;
        }

        /* Base Resets */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', sans-serif;
            color: var(--dark);
            background-color: var(--white);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Navbar - Glassmorphism Sticky */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(220, 220, 220, 0.3);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
            transition: var(--transition);
        }

        .header.scrolled {
            background: rgba(255, 255, 255, 0.95);
            padding: 12px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .nav-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0;
            transition: var(--transition);
        }

        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-img {
            height: 42px;
            width: auto;
        }

        .logo-text {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: -0.5px;
        }

        .nav-menu {
            display: flex;
            align-items: center;
            gap: 32px;
        }

        .nav-link {
            font-size: 16px;
            font-weight: 500;
            color: var(--dark);
            position: relative;
            padding: 8px 0;
            transition: var(--transition);
            opacity: 0.85;
        }

        .nav-link:hover {
            color: var(--primary);
            opacity: 1;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--primary);
            transition: var(--transition);
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: var(--border-radius);
            font-size: 15px;
            font-weight: 600;
            transition: var(--transition);
            cursor: pointer;
            border: none;
        }

        .btn-text {
            color: var(--dark);
            background: transparent;
            opacity: 0.85;
        }

        .btn-text:hover {
            color: var(--primary);
            opacity: 1;
        }

        .btn-primary {
            background-color: var(--primary);
            color: var(--white);
            box-shadow: 0 4px 14px rgba(255, 138, 0, 0.2);
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 138, 0, 0.3);
        }

        .btn-outline {
            background-color: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background-color: var(--primary-light);
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero {
            padding: 160px 0 100px 0;
            background: linear-gradient(180deg, #FFF9F2 0%, #FFFFFF 100%);
            position: relative;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 60px;
            align-items: center;
        }

        .badge-campus {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background-color: var(--primary-light);
            color: var(--primary);
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 24px;
            box-shadow: 0 2px 10px rgba(255, 138, 0, 0.05);
        }

        .hero-title {
            font-size: 56px;
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -1.5px;
            margin-bottom: 24px;
        }

        .hero-title span {
            color: var(--primary);
        }

        .hero-desc {
            font-size: 18px;
            color: var(--gray);
            margin-bottom: 40px;
            max-width: 520px;
        }

        .hero-cta {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .hero-image-wrapper {
            position: relative;
        }

        .hero-img {
            border-radius: 24px;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.08));
        }

        .widget-delivery {
            position: absolute;
            bottom: 24px;
            left: -30px;
            background-color: var(--white);
            padding: 16px 24px;
            border-radius: var(--border-radius);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            gap: 16px;
            animation: float 6s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .widget-icon {
            width: 48px;
            height: 48px;
            background-color: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
        }

        .widget-info p {
            font-size: 12px;
            color: var(--gray);
            font-weight: 500;
        }

        .widget-info h4 {
            font-size: 16px;
            font-weight: 700;
        }

        /* Designed for Student Life (Features) */
        .section {
            padding: 100px 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title {
            font-size: 40px;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 16px;
        }

        .section-subtitle {
            font-size: 17px;
            color: var(--gray);
            max-width: 600px;
            margin: 0 auto;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .feature-card {
            background-color: var(--white);
            border: 1px solid var(--gray-light);
            border-radius: var(--border-radius);
            padding: 32px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 0;
            background-color: var(--primary);
            transition: var(--transition);
        }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow);
            border-color: transparent;
        }

        .feature-card:hover::before {
            height: 100%;
        }

        .feature-icon-box {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            background-color: var(--primary-light);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
        }

        .feature-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .feature-desc {
            font-size: 15px;
            color: var(--gray);
        }

        /* How It Works (Workflow) */
        .workflow {
            background-color: #FAFBFD;
        }

        .workflow-timeline {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            position: relative;
            margin-top: 40px;
        }

        .workflow-timeline::after {
            content: '';
            position: absolute;
            top: 44px;
            left: 5%;
            right: 5%;
            height: 2px;
            background-color: var(--gray-light);
            z-index: 1;
        }

        .workflow-step {
            width: 22%;
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .step-number {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background-color: var(--white);
            border: 2px solid var(--primary);
            color: var(--primary);
            font-size: 20px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px auto;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
            transition: var(--transition);
        }

        .workflow-step:hover .step-number {
            background-color: var(--primary);
            color: var(--white);
            transform: scale(1.1);
            box-shadow: var(--shadow-hover);
        }

        .step-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .step-desc {
            font-size: 14px;
            color: var(--gray);
            padding: 0 10px;
        }

        /* Stats & Platform */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 64px;
        }

        .stat-card {
            background-color: var(--white);
            padding: 28px 24px;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            border: 1px solid rgba(0,0,0,0.04);
            transition: var(--transition);
            text-align: center;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

        .stat-number {
            font-size: 42px;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 6px;
            display: flex;
            align-items: baseline;
            justify-content: center;
        }

        .stat-number span {
            font-size: 24px;
            margin-left: 2px;
        }

        .stat-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .platform-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .platform-img {
            border-radius: 24px;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.08));
            width: 100%;
        }

        /* CTA Section */
        .cta {
            padding: 80px 0;
            background: linear-gradient(135deg, #FF9E2C 0%, #FF7A00 100%);
            border-radius: 28px;
            margin-bottom: 100px;
            position: relative;
            overflow: hidden;
        }

        .cta::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            top: -100px;
            right: -100px;
        }

        .cta::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            bottom: -50px;
            left: -50px;
        }

        .cta-content {
            text-align: center;
            color: var(--white);
            position: relative;
            z-index: 5;
        }

        .cta-title {
            font-size: 42px;
            font-weight: 800;
            margin-bottom: 16px;
            letter-spacing: -1px;
        }

        .cta-desc {
            font-size: 18px;
            opacity: 0.9;
            margin-bottom: 36px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-buttons {
            display: flex;
            justify-content: center;
            gap: 16px;
        }

        .btn-white {
            background-color: var(--white);
            color: var(--primary);
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        }

        .btn-white:hover {
            transform: translateY(-2px);
            background-color: var(--light);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        }

        /* Footer */
        .footer {
            background-color: #F8F9FA;
            padding: 80px 0 40px 0;
            border-top: 1px solid var(--gray-light);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 60px;
        }

        .footer-brand p {
            color: var(--gray);
            margin-top: 16px;
            font-size: 15px;
            max-width: 260px;
        }

        .footer-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 24px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .footer-links li {
            margin-bottom: 12px;
        }

        .footer-links a {
            color: var(--gray);
            font-size: 15px;
            transition: var(--transition);
        }

        .footer-links a:hover {
            color: var(--primary);
            padding-left: 4px;
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 40px;
            border-top: 1px solid var(--gray-light);
            font-size: 14px;
            color: var(--gray);
        }

        .social-links {
            display: flex;
            gap: 16px;
        }

        .social-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--gray-light);
            transition: var(--transition);
        }

        .social-icon:hover {
            background-color: var(--primary);
            color: var(--white);
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        /* Modal styling */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal.active {
            opacity: 1;
            pointer-events: all;
        }

        .modal-content {
            background: var(--white);
            padding: 40px;
            border-radius: 24px;
            max-width: 480px;
            width: 90%;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            text-align: center;
            position: relative;
            transform: scale(0.9);
            transition: transform 0.3s ease;
        }

        .modal.active .modal-content {
            transform: scale(1);
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 24px;
            cursor: pointer;
            color: var(--gray);
            transition: var(--transition);
        }

        .modal-close:hover {
            color: var(--dark);
        }

        .qr-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 30px 0;
        }

        .qr-card {
            border: 1px solid var(--gray-light);
            padding: 16px;
            border-radius: var(--border-radius);
        }

        .qr-placeholder {
            width: 120px;
            height: 120px;
            background-color: var(--light);
            margin: 0 auto 12px auto;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px dashed var(--primary);
        }

        /* Responsiveness */
        @@media (max-width: 992px) {
            .hero-grid {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 40px;
            }
            .hero-desc {
                margin: 0 auto 40px auto;
            }
            .hero-cta {
                justify-content: center;
            }
            .widget-delivery {
                left: 20px;
            }
            .features-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .workflow-timeline {
                flex-direction: column;
                gap: 40px;
            }
            .workflow-timeline::after {
                display: none;
            }
            .workflow-step {
                width: 100%;
                display: flex;
                text-align: left;
                align-items: center;
                gap: 20px;
            }
            .step-number {
                margin: 0;
            }
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
            .platform-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 576px) {
            .features-grid {
                grid-template-columns: 1fr;
            }
            .nav-menu {
                display: none;
            }
            .footer-grid {
                grid-template-columns: 1fr;
            }
            .hero-title {
                font-size: 38px;
            }
        }
    </style>
</head>
<body>

    <!-- Header / Navbar -->
    <header class="header" id="header">
        <div class="container nav-container">
            <a href="#home" class="logo-wrapper">
                <img src="/logo.png" class="logo-img" alt="StudentFood COFER Logo">
                <span class="logo-text">StudentFood COFER</span>
            </a>
            
            <nav class="nav-menu">
                <a href="#home" class="nav-link">Home</a>
                <a href="#features" class="nav-link">Features</a>
                <a href="#workflow" class="nav-link">Workflow</a>
                <a href="#about" class="nav-link">About</a>
                <a href="#contact" class="nav-link">Download</a>
            </nav>
            
            <div class="nav-actions">
                <button onclick="toggleModal(true)" class="btn btn-primary">Get Started</button>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="container hero-grid">
            <div class="hero-content">
                <div class="badge-campus">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                        <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    Direct Campus Delivery System
                </div>
                <h1 class="hero-title">Order Food on Campus,<br><span>Fast and Easy.</span></h1>
                <p class="hero-desc">StudentFood COFER là nền tảng đặt đồ ăn học đường hiện đại kết nối trực tiếp sinh viên với các quầy căn tin trong trường, giao hàng nội bộ nhanh chóng và tiện lợi.</p>
                <div class="hero-cta">
                    <button onclick="toggleModal(true)" class="btn btn-primary">Order with App</button>
                </div>
            </div>
            
            <div class="hero-image-wrapper">
                <img src="/images/hero_delivery.png" class="hero-img" alt="StudentFood COFER Campus Delivery System">
                <div class="widget-delivery">
                    <div class="widget-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 14 14"></polyline>
                        </svg>
                    </div>
                    <div class="widget-info">
                        <p>Average Delivery</p>
                        <h4>12 Minutes</h4>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="section" id="features">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Designed for Student Life</h2>
                <p class="section-subtitle">Tiết kiệm thời gian xếp hàng chờ đợi, tập trung học tập trong khi chúng tôi chuẩn bị bữa ăn nóng hổi cho bạn.</p>
            </div>
            
            <div class="features-grid">
                <!-- Card 1 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                        </svg>
                    </div>
                    <h3 class="feature-title">Fast Ordering</h3>
                    <p class="feature-desc">Hệ thống đặt món một chạm tối ưu hóa tốc độ, giúp bạn nhanh chóng có bữa ăn giữa các ca học.</p>
                </div>
                <!-- Card 2 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                    </div>
                    <h3 class="feature-title">Real-time Tracking</h3>
                    <p class="feature-desc">Theo dõi chính xác trạng thái chuẩn bị món và lộ trình di chuyển của shipper trực tiếp trên bản đồ.</p>
                </div>
                <!-- Card 3 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                            <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">Campus Delivery</h3>
                    <p class="feature-desc">Giao hàng tận nơi tại mọi ngóc ngách trong khuôn viên trường: giảng đường, ký túc xá, thư viện.</p>
                </div>
                <!-- Card 4 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">Secure Payment</h3>
                    <p class="feature-desc">Hỗ trợ đa dạng phương thức thanh toán an toàn: Tiền mặt, chuyển khoản ngân hàng hoặc ví điện tử liên kết.</p>
                </div>
                <!-- Card 5 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">Fresh Meals</h3>
                    <p class="feature-desc">Hợp tác trực tiếp với các quầy thực phẩm uy tín đảm bảo đồ ăn luôn nóng hổi, vệ sinh và chất lượng.</p>
                </div>
                <!-- Card 6 -->
                <div class="feature-card">
                    <div class="feature-icon-box">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <h3 class="feature-title">Student Friendly</h3>
                    <p class="feature-desc">Mức giá cực kỳ sinh viên, nhiều chương trình tích lũy điểm và ưu đãi thiết kế dành riêng cho bạn.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Workflow Section -->
    <section class="section workflow" id="workflow">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">How It Works</h2>
                <p class="section-subtitle">Chỉ với 4 bước đơn giản để trải nghiệm ẩm thực tiện lợi ngay tại giảng đường.</p>
            </div>
            
            <div class="workflow-timeline">
                <!-- Step 1 -->
                <div class="workflow-step">
                    <div class="step-number">1</div>
                    <h3 class="step-title">Browse Menu</h3>
                    <p class="step-desc">Khám phá các quầy ăn đa dạng trên ứng dụng, tìm kiếm món ăn yêu thích dễ dàng.</p>
                </div>
                <!-- Step 2 -->
                <div class="workflow-step">
                    <div class="step-number">2</div>
                    <h3 class="step-title">Customize</h3>
                    <p class="step-desc">Lựa chọn số lượng và ghi chú thêm cho món ăn theo sở thích khẩu vị cá nhân.</p>
                </div>
                <!-- Step 3 -->
                <div class="workflow-step">
                    <div class="step-number">3</div>
                    <h3 class="step-title">Checkout</h3>
                    <p class="step-desc">Thanh toán bảo mật nhanh chóng qua ngân hàng trực tuyến hoặc chọn trả tiền mặt khi nhận hàng.</p>
                </div>
                <!-- Step 4 -->
                <div class="workflow-step">
                    <div class="step-number">4</div>
                    <h3 class="step-title">Preparation</h3>
                    <p class="step-desc">Căn tin chuẩn bị món ngay lập tức và đội ngũ shipper giao nóng hổi đến tay bạn.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="section" id="about">
        <div class="container">
            <!-- 4 Stats in a single horizontal row -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-number">@ViewBag.ActiveStudents</div>
                    <div class="stat-label">Active Students</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@ViewBag.OrdersDelivered</div>
                    <div class="stat-label">Orders Delivered</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">99.9%</div>
                    <div class="stat-label">System Uptime</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@ViewBag.PartnerShops</div>
                    <div class="stat-label">Partner Shops</div>
                </div>
            </div>

            <!-- One Platform text + image side by side -->
            <div class="platform-grid">
                <div>
                    <h2 class="section-title" style="margin-bottom: 24px;">One Platform,<br><span style="color: var(--primary);">Endless Connections</span></h2>
                    <p class="hero-desc" style="margin-bottom: 0;">Hệ thống tích hợp hiện đại đồng bộ hóa giữa sinh viên, nhân viên căn tin và quản trị viên trường học, đem lại quy trình vận hành khép kín hoàn hảo.</p>
                </div>
                <div>
                    <img src="/images/oneplatform.png" class="platform-img" alt="StudentFood COFER Platform">
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="container" id="contact">
        <div class="cta">
            <div class="cta-content">
                <h2 class="cta-title">Ready to order your favorite meal?</h2>
                <p class="cta-desc">Tải ứng dụng StudentFood COFER ngay hôm nay để tận hưởng ưu đãi đặc quyền cho ca học tiếp theo của bạn.</p>
                <div class="cta-buttons">
                    <button onclick="toggleModal(true)" class="btn btn-white">Download Now</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="logo-wrapper">
                        <img src="/logo.png" class="logo-img" alt="StudentFood COFER Logo">
                        <span class="logo-text">StudentFood COFER</span>
                    </div>
                    <p>Giải pháp công nghệ tối ưu ẩm thực học đường, mang đến bữa ăn tiện lợi cho sinh viên.</p>
                </div>
                <div>
                    <h4 class="footer-title">Platform</h4>
                    <ul class="footer-links">
                        <li><a href="#home">Home</a></li>
                        <li><a href="#features">Features</a></li>
                        <li><a href="#workflow">Workflow</a></li>
                        <li><a href="#about">About</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer-title">Contact Us</h4>
                    <ul class="footer-links">
                        <li><a href="mailto:support@studentfood.cofer.vn">support@studentfood.cofer.vn</a></li>
                        <li><a href="tel:0281234567">028 123 4567</a></li>
                        <li><a href="#">Trường Cao đẳng Kinh tế Đối ngoại</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="footer-title">Legal</h4>
                    <ul class="footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year StudentFood COFER. All rights reserved.</p>
                <div class="social-links">
                    <a href="#" class="social-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                        </svg>
                    </a>
                    <a href="#" class="social-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                    <a href="#" class="social-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- App Download Modal -->
    <div class="modal" id="downloadModal">
        <div class="modal-content">
            <span onclick="toggleModal(false)" class="modal-close">&times;</span>
            <h3 style="font-size: 24px; font-weight: 700; margin-bottom: 12px; color: var(--primary);">Tải Ứng Dụng Đặt Đồ Ăn</h3>
            <p style="color: var(--gray); font-size: 15px;">Nhấn nút dưới đây để tải file APK của ứng dụng StudentFood COFER.</p>
            
            <div style="margin: 30px 0;">
                <a href="/apk/StudentFoodCOFER.apk" download class="btn btn-primary" style="width: 100%; font-size: 16px; padding: 16px;">
                    📱 Tải File APK
                </a>
            </div>
            
            <button onclick="toggleModal(false)" class="btn btn-outline" style="width: 100%;">Đóng lại</button>
        </div>
    </div>

    <script>
        // Header scroll effect
        window.addEventListener('scroll', function() {
            const header = document.getElementById('header');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        // Toggle Modal Function
        function toggleModal(show) {
            const modal = document.getElementById('downloadModal');
            if (show) {
                modal.classList.add('active');
            } else {
                modal.classList.remove('active');
            }
        }

        // Close modal when clicking outside
        window.addEventListener('click', function(e) {
            const modal = document.getElementById('downloadModal');
            if (e.target === modal) {
                modal.classList.remove('active');
            }
        });
    </script>
</body>
</html>
